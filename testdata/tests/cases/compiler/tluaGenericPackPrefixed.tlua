// @strict: true
// @target: esnext

// Prefixed packs: this file pins the boundary between what generic packs
// support and the one shape that is fundamentally ambiguous. tlua matches
// upstream TypeScript (variadicTuples `curry` vs `curry2`) and Luau here.

// 1. A fixed element before a LONE pack correlates -- the shipped `pcall`/
//    `assert` shape `(boolean, ...R)` / `(T, ...M)`. The split point is
//    unambiguous because the single variadic consumes everything after the
//    fixed prefix.
declare function prepend<T, ...A>(head: T, ...: A): (T, ...A);
local a, b, c = prepend(true, 1, "x");
// a: boolean, b: number, c: string

// 2. Two ADJACENT packs correlate when each is inferred from its OWN source:
//    every pack has a definite arity, so there is no split to guess.
declare function both<...A, ...B>(
    f: (...: A) => (...A),
    g: (...: B) => (...B),
): (...A, ...B);
local x, y = both(
    function(n: number): (number) return n; end,
    function(s: string): (string) return s; end,
);
// x: number, y: string

// 3. Inferring the split of two adjacent packs from a SINGLE source pack is
//    ambiguous -- nothing says where A ends and B begins. tlua declines
//    (the packs degrade to the open `(...any)`), exactly as upstream declines
//    `curry2`. This is the documented limitation, pinned so a future change to
//    variadic-tuple inference is a deliberate decision, not an accident.
declare function split<...A, ...B>(source: () => (...A, ...B)): (...A);
declare function pair(): (number, string);
local p, q = split(pair);
// p: any, q: any -- the ambiguous split, not (number)
