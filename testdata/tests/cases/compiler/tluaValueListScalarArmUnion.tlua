// @strict: true
// @noEmit: true

// A mixed union with a NON-pack (scalar/nil) arm as a value-list tail must not
// normalize the scalar arm to an errorType. `nil | (number, string)` distributes
// per position, so both names get real types.
declare function f(): nil | (number, string)

// A lone call already distributed correctly (packElementForIndex handles the scalar
// arm); pin it so it stays that way.
local a, b = f();
local va: number | nil = a;
local vb: string | nil = b;

// The exposed path: the mixed union spliced as a NON-leading value in an expression
// list. `d` is the second value -- `number` from the pack arm or `nil` from the
// scalar arm -- and must be `number | nil`, never `any` (an errorType rest element
// from treating the `nil` arm as an array-to-spread).
local c, d = 1, f();
local vd: number | nil = d;
