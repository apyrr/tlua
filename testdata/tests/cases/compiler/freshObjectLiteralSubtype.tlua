// @strict: true
// @noEmit: true
// @target: esnext

function f1()
    if (!!true) then
        return { valid = true }
    end
    return f2()
end

declare f2: () => { valid: boolean, msg?: undefined }

f1().msg

// Repro from https://github.com/microsoft/typescript-go/issues/1742

function validate()
    if(Math.random() > 0.5) then
        return utilValidate();
    end
    return { valid = true };
end;


declare function utilValidate(): {
    valid: boolean;
    msg?: undefined;
} | {
    valid: boolean;
    msg: string;
}

validate().msg; // Error in TLUA

// https://github.com/microsoft/typescript-go/issues/1761

function normalise_trace_logs([log]: any[])
	local normalised = [];
    if (typeof log == "string" && log.includes("%c")) then
        normalised.push({ log, highlighted = log.includes("foo") });
    else
        normalised.push({ log });
    end
	return normalised;
end

function equal<T>(_actual: T, _expected: T): void end

equal(normalise_trace_logs([]), [
    { log = 'effect' },
    { log = '$derived', highlighted = true },
    { log = 'double', highlighted = false },
    { log = 4 },
]);
