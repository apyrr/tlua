// @strict: true
// @noEmit: true

// A tuple declared in a .d.tlua flows into .tlua source and is indexed at the
// 1-based Lua sequence keys; key 0 is out of range.

// @filename: shapes.d.tlua
declare pair: [number, string];
declare function makeTriple(): [boolean, number, string];
declare nested: [[number, number], string];

// @filename: main.tlua
local a: number = pair[1];
local b: string = pair[2];

local triple = makeTriple();
local t1: boolean = triple[1];
local t3: string = triple[3];

local inner: number = nested[1][2];

local oob = pair[0];

local es = {a, b, t1, t3, inner};
