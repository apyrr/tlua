// @strict: true
// @target: esnext
// @noEmit: true

// https://github.com/microsoft/typescript-go/issues/849

declare function useMemo<T>(func: () => T): T;

function getPredicate(alwaysTrue: boolean)
    local predicate: (input: string) => boolean = useMemo(function()
        if (alwaysTrue) then
            return function() return true end;
        end
        return function(x) return x.length > 0 end;
    end);
    return predicate;
end

// https://github.com/microsoft/typescript-go/issues/1016

declare function compact<T>(array: T[]): T[];
declare function makeFooer(): Fooer;
interface Fooer {
    foo: (v: string) => string;
}
function f()
    local _ = compact([makeFooer(), { foo = function(v) return v end }]);
end
