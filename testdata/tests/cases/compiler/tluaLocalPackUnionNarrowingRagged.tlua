// @strict: true
// @noEmit: true

// Arms of DIFFERENT arity. The discriminant below sits at position 2, which
// exists only in the longer arm -- narrowing keys on a number-key property that
// must be present in every constituent, so without padding the shorter arm to the
// union's widest arity this position discriminates nothing.
//
// Note the position matters: discriminating at position 1 (present in both arms)
// would pass whether or not the padding works, and would hide the bug.
declare function ragged(): (number, nil) | (nil, string, boolean)

local v, e, flag = ragged();
if flag ~= nil then
  // Selects the three-element arm.
  local ee: string = e;
  local none: nil = v;
end

// The short arm is still reachable, and padding does not invent values: position
// 2 reads as nil there, exactly as Lua returns it.
local v2, e2, flag2 = ragged();
if flag2 == nil then
  local n2: number = v2;
  local none2: nil = e2;
end
