// @strict: true
// @noEmit: true

// `keyof` over an all-fixed tuple yields exactly its element key literals
// (1 | 2 | ...); only a variable-length tuple widens to the `number` index of
// the underlying table. Neither includes `length` (a tuple value is a plain
// table with no length field; `#t` is an operator) nor the members of the
// inert global `Array` (push/pop/map/...), which tlua tuples no longer
// inherit. This holds for concrete tuples (resolved from their members) and,
// crucially, for generic variadic tuples, whose known keys flow through the
// relater (getKnownKeysOfTupleType).

// @filename: shapes.d.tlua
declare pair: [string, boolean];

// The default type argument `"push"` is validated against the constraint
// `keyof [number, ...T]` while `T` is still generic. A tuple has no `push`
// member, so this default is not a valid key of the tuple.
interface KeyBox<T extends unknown[], K extends keyof [number, ...T] = "push"> {
  key: K;
}

// @filename: main.tlua
// Numeric indices are keys of the tuple; `length` and Array method names are not.
local ok1: keyof typeof pair = 1;
local badLen: keyof typeof pair = "length";
local bad: keyof typeof pair = "push";

local es = {ok1, badLen};
