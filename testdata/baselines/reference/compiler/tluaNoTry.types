//// [tests/cases/compiler/tluaNoTry.tlua] ////

=== tluaNoTry.tlua ===
// try/catch/finally are removed. The words are ordinary identifiers, so this
// reports ordinary syntax errors without constructing legacy AST nodes.
try {
>try : any

  throw "boom";
>"boom" : "boom"

} catch (e) {
>catch (e) : any
>catch : any
>e : any

  local caught = e;
>caught : any
>e : any

} finally {
>finally : any

  local cleaned = true;
>cleaned : boolean
>true : true
}

