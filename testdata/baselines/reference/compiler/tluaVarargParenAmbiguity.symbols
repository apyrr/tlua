//// [tests/cases/compiler/tluaVarargParenAmbiguity.tlua] ////

=== tluaVarargParenAmbiguity.tlua ===
// `(...` is ambiguous between an arrow parameter list, the Lua single-value
// truncation idiom `(...)`, and `...` as an operand inside parentheses. The
// arrow lookahead must not commit where the expression reading is the legal
// one: committing turns legal code into a parse error, and a parse error
// suppresses every semantic diagnostic in the program. The main chunk is a
// vararg function, so a top-level `...` is legal throughout.

declare n: number;
>n : Symbol(n, Decl(tluaVarargParenAmbiguity.tlua, 7, 7))

// A parenthesized expression list is an expression, with or without a vararg
// inside it.
local plain = (1, 2);
>plain : Symbol(plain, Decl(tluaVarargParenAmbiguity.tlua, 11, 5))

local withVararg = (..., 2);
>withVararg : Symbol(withVararg, Decl(tluaVarargParenAmbiguity.tlua, 12, 5))

// Still arrows: a bare vararg parameter list, one with the (ambiguous) return
// type colon, and an annotated vararg.
local arrow = function(...) return 1 end;
>arrow : Symbol(arrow, Decl(tluaVarargParenAmbiguity.tlua, 16, 5))
> : Symbol((Missing), Decl(tluaVarargParenAmbiguity.tlua, 16, 23))

local arrowWithReturnType = function(...): number return 2 end;
>arrowWithReturnType : Symbol(arrowWithReturnType, Decl(tluaVarargParenAmbiguity.tlua, 17, 5))
> : Symbol((Missing), Decl(tluaVarargParenAmbiguity.tlua, 17, 37))

local arrowAnnotated = function(...: string) return 3 end;
>arrowAnnotated : Symbol(arrowAnnotated, Decl(tluaVarargParenAmbiguity.tlua, 18, 5))
> : Symbol((Missing), Decl(tluaVarargParenAmbiguity.tlua, 18, 32))

// A misplaced vararg is still an arrow when the `=>` says so -- the parameter
// grammar reports it precisely (a rest parameter must be last).
local misplacedInArrow = function(..., x: number) return x end;
>misplacedInArrow : Symbol(misplacedInArrow, Decl(tluaVarargParenAmbiguity.tlua, 22, 5))
> : Symbol((Missing), Decl(tluaVarargParenAmbiguity.tlua, 22, 34))
>x : Symbol(x, Decl(tluaVarargParenAmbiguity.tlua, 22, 38))
>x : Symbol(x, Decl(tluaVarargParenAmbiguity.tlua, 22, 38))

// Without the `=>` the same shape is an expression list, not a mangled arrow.
local notAnArrow = (..., n);
>notAnArrow : Symbol(notAnArrow, Decl(tluaVarargParenAmbiguity.tlua, 25, 5))
>n : Symbol(n, Decl(tluaVarargParenAmbiguity.tlua, 7, 7))

