>a : Symbol(a, Decl(tluaMetatableDebug.tlua, 3, 53))
>__metatable : Symbol(__metatable, Decl(tluaMetatableDebug.tlua, 3, 62))

// debug.getmetatable sees the real metatable, not the sentinel.
local real = debug.getmetatable(guarded);
>real : Symbol(real, Decl(tluaMetatableDebug.tlua, 6, 5))
