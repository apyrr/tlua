//// [tests/cases/compiler/tluaControlFlowCoexistence.tlua] ////

=== tluaControlFlowCoexistence.tlua ===
// Lua control-flow forms parse and emit.
function ifForms(flag: boolean): number
>ifForms : (flag: boolean) => number
>flag : boolean

  if flag then
>flag : boolean

    return 1;
>1 : 1

  end
  if flag then return 2 end
>flag : false
>2 : 2

  if flag then return 3 else return 4 end
>flag : false
>3 : 3
>4 : 4

  return 0;
>0 : 0

end

// Loop forms, including a repeat/until standing in for the old do-while.
function loopForms(flag: boolean): number
>loopForms : (flag: boolean) => number
>flag : boolean

  while flag do
>flag : boolean

    flag = false;
>flag = false : false
>flag : boolean
>false : false

  end
  repeat
    flag = false;
>flag = false : false
>flag : boolean
>false : false

  until not (flag)
>not (flag) : true
>(flag) : false
>flag : false

  return 0;
>0 : 0

end

// Nested control flow.
function nested(flag: boolean): number
>nested : (flag: boolean) => number
>flag : boolean

  if flag then
>flag : boolean

    if flag then
>flag : true

      return 1;
>1 : 1

    end
  end
  while flag do
>flag : false

    while flag do
>flag : false

      flag = false;
>flag = false : false
>flag : boolean
>false : false

    end
  end
  return 0;
>0 : 0

end

