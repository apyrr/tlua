//// [tests/cases/compiler/tluaWordOperatorJsxNames.tsx] ////

=== tluaWordOperatorJsxNames.tsx ===
// A JSX name is an IdentifierName position, so the word-spelled operators are
// ordinary names there. Unlike the member name `t.and`, which must be written
// `t["and"]`, a JSX tag or attribute name has no alternative spelling.

interface JsxElement {}
>JsxElement : Symbol(JsxElement, Decl(tluaWordOperatorJsxNames.tsx, 0, 0))

interface JsxIntrinsicElements {
>JsxIntrinsicElements : Symbol(JsxIntrinsicElements, Decl(tluaWordOperatorJsxNames.tsx, 4, 23))

    // Member names, so the word operators are quoted here.
    div: { "and"?: boolean; "or"?: boolean; "not"?: boolean; "not-dashed"?: number };
>div : Symbol(JsxIntrinsicElements.div, Decl(tluaWordOperatorJsxNames.tsx, 5, 32))
>"and" : Symbol("and", Decl(tluaWordOperatorJsxNames.tsx, 7, 10))
>"or" : Symbol("or", Decl(tluaWordOperatorJsxNames.tsx, 7, 27))
>"not" : Symbol("not", Decl(tluaWordOperatorJsxNames.tsx, 7, 43))
>"not-dashed" : Symbol("not-dashed", Decl(tluaWordOperatorJsxNames.tsx, 7, 60))

    "or": { "and"?: boolean };
>"or" : Symbol(JsxIntrinsicElements["or"], Decl(tluaWordOperatorJsxNames.tsx, 7, 85))
>"and" : Symbol("and", Decl(tluaWordOperatorJsxNames.tsx, 8, 11))
}

declare p: boolean;
>p : Symbol(p, Decl(tluaWordOperatorJsxNames.tsx, 11, 7))

declare q: boolean;
>q : Symbol(q, Decl(tluaWordOperatorJsxNames.tsx, 12, 7))

// Attribute names.
local attrs = <div and={p} or={q} not={p} />;
>attrs : Symbol(attrs, Decl(tluaWordOperatorJsxNames.tsx, 15, 5))
>div : Symbol(JsxIntrinsicElements.div, Decl(tluaWordOperatorJsxNames.tsx, 5, 32))
>and : Symbol(and, Decl(tluaWordOperatorJsxNames.tsx, 15, 18))
>p : Symbol(p, Decl(tluaWordOperatorJsxNames.tsx, 11, 7))
>or : Symbol(or, Decl(tluaWordOperatorJsxNames.tsx, 15, 26))
>q : Symbol(q, Decl(tluaWordOperatorJsxNames.tsx, 12, 7))
>not : Symbol(not, Decl(tluaWordOperatorJsxNames.tsx, 15, 33))
>p : Symbol(p, Decl(tluaWordOperatorJsxNames.tsx, 11, 7))

// A dash resumes the name after the word, so `not-dashed` is one attribute.
local dashed = <div not-dashed={1} />;
>dashed : Symbol(dashed, Decl(tluaWordOperatorJsxNames.tsx, 18, 5))
>div : Symbol(JsxIntrinsicElements.div, Decl(tluaWordOperatorJsxNames.tsx, 5, 32))
>not-dashed : Symbol(not-dashed, Decl(tluaWordOperatorJsxNames.tsx, 18, 19))

// Tag name, including the closing tag.
local tag = <or and={p}></or>;
>tag : Symbol(tag, Decl(tluaWordOperatorJsxNames.tsx, 21, 5))
>or : Symbol(JsxIntrinsicElements["or"], Decl(tluaWordOperatorJsxNames.tsx, 7, 85))
>and : Symbol(and, Decl(tluaWordOperatorJsxNames.tsx, 21, 15))
>p : Symbol(p, Decl(tluaWordOperatorJsxNames.tsx, 11, 7))
>or : Symbol(JsxIntrinsicElements["or"], Decl(tluaWordOperatorJsxNames.tsx, 7, 85))

// The operators still operate inside an expression container.
local operators = <div and={p and q} or={p or q} not={not p} />;
>operators : Symbol(operators, Decl(tluaWordOperatorJsxNames.tsx, 24, 5))
>div : Symbol(JsxIntrinsicElements.div, Decl(tluaWordOperatorJsxNames.tsx, 5, 32))
>and : Symbol(and, Decl(tluaWordOperatorJsxNames.tsx, 24, 22))
>p : Symbol(p, Decl(tluaWordOperatorJsxNames.tsx, 11, 7))
>q : Symbol(q, Decl(tluaWordOperatorJsxNames.tsx, 12, 7))
>or : Symbol(or, Decl(tluaWordOperatorJsxNames.tsx, 24, 36))
>p : Symbol(p, Decl(tluaWordOperatorJsxNames.tsx, 11, 7))
>q : Symbol(q, Decl(tluaWordOperatorJsxNames.tsx, 12, 7))
>not : Symbol(not, Decl(tluaWordOperatorJsxNames.tsx, 24, 48))
>p : Symbol(p, Decl(tluaWordOperatorJsxNames.tsx, 11, 7))

// A word operator after a dot is a member name, so it stays an error, exactly
// as `t.and` does.
declare Ns: { "and": () => JsxElement };
>Ns : Symbol(Ns, Decl(tluaWordOperatorJsxNames.tsx, 28, 7))
>"and" : Symbol("and", Decl(tluaWordOperatorJsxNames.tsx, 28, 13))
>JsxElement : Symbol(JsxElement, Decl(tluaWordOperatorJsxNames.tsx, 0, 0))

local dotted = <Ns.and />;
>dotted : Symbol(dotted, Decl(tluaWordOperatorJsxNames.tsx, 29, 5))
>Ns : Symbol(Ns, Decl(tluaWordOperatorJsxNames.tsx, 28, 7))
>and : Symbol(and, Decl(tluaWordOperatorJsxNames.tsx, 29, 19))

