//// [tests/cases/compiler/inferFromTupleRestAndVariadic.tlua] ////

=== inferFromTupleRestAndVariadic.tlua ===
// Crash when inferring from tuple types with rest and variadic elements
// where the variadic element's constraint consumes all source tuple elements.
// The pattern [...rest, ...T] where T is constrained by a fixed-size tuple
// calls getElementTypeOfSliceOfTupleType which can return nil when the
// source tuple is entirely consumed by T's implied arity.

type SubTup<T> = T extends [
>SubTup : Symbol(SubTup, Decl(inferFromTupleRestAndVariadic.tlua, 0, 0))
>T : Symbol(T, Decl(inferFromTupleRestAndVariadic.tlua, 6, 12))
>T : Symbol(T, Decl(inferFromTupleRestAndVariadic.tlua, 6, 12))

    ...(infer C)[],
>C : Symbol(C, Decl(inferFromTupleRestAndVariadic.tlua, 7, 13))

    ...infer B extends [any, any]
>B : Symbol(B, Decl(inferFromTupleRestAndVariadic.tlua, 8, 12))

] ? B : never;
>B : Symbol(B, Decl(inferFromTupleRestAndVariadic.tlua, 8, 12))

type Trigger = SubTup<[1, 2]>;
>Trigger : Symbol(Trigger, Decl(inferFromTupleRestAndVariadic.tlua, 9, 14))
>SubTup : Symbol(SubTup, Decl(inferFromTupleRestAndVariadic.tlua, 0, 0))

// Also test the [...T, ...rest] pattern
type SubTup2<T> = T extends [
>SubTup2 : Symbol(SubTup2, Decl(inferFromTupleRestAndVariadic.tlua, 10, 30))
>T : Symbol(T, Decl(inferFromTupleRestAndVariadic.tlua, 13, 13))
>T : Symbol(T, Decl(inferFromTupleRestAndVariadic.tlua, 13, 13))

    ...infer A extends [any, any],
>A : Symbol(A, Decl(inferFromTupleRestAndVariadic.tlua, 14, 12))

    ...(infer D)[],
>D : Symbol(D, Decl(inferFromTupleRestAndVariadic.tlua, 15, 13))

] ? A : never;
>A : Symbol(A, Decl(inferFromTupleRestAndVariadic.tlua, 14, 12))

type Trigger2 = SubTup2<[1, 2]>;
>Trigger2 : Symbol(Trigger2, Decl(inferFromTupleRestAndVariadic.tlua, 16, 14))
>SubTup2 : Symbol(SubTup2, Decl(inferFromTupleRestAndVariadic.tlua, 10, 30))

// Test with more elements than implied arity (should work fine)
type Trigger3 = SubTup<[1, 2, 3, 4]>;
>Trigger3 : Symbol(Trigger3, Decl(inferFromTupleRestAndVariadic.tlua, 17, 32))
>SubTup : Symbol(SubTup, Decl(inferFromTupleRestAndVariadic.tlua, 0, 0))

type Trigger4 = SubTup2<[1, 2, 3, 4]>;
>Trigger4 : Symbol(Trigger4, Decl(inferFromTupleRestAndVariadic.tlua, 20, 37))
>SubTup2 : Symbol(SubTup2, Decl(inferFromTupleRestAndVariadic.tlua, 10, 30))

