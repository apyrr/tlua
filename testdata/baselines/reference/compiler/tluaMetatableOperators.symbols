local v = setmetatable({ x = 1 }, Ops);
>v : Symbol(v, Decl(tluaMetatableOperators.tlua, 13, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>x : Symbol(x, Decl(tluaMetatableOperators.tlua, 13, 24))
