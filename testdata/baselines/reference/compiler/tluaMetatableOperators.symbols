>a : Symbol(a, Decl(tluaMetatableOperators.tlua, 4, 19))

  __mul = function(a: { x: number }, s: number): (number, string) return a.x * s, "w"; end,
>__mul : Symbol(__mul, Decl(tluaMetatableOperators.tlua, 4, 93))
>a : Symbol(a, Decl(tluaMetatableOperators.tlua, 5, 19))
