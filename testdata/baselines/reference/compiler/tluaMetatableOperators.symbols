>s : Symbol(s, Decl(tluaMetatableOperators.tlua, 5, 36))

  __lt = function(a: { x: number }, b: { x: number }): boolean return a.x < b.x; end,
>__lt : Symbol(__lt, Decl(tluaMetatableOperators.tlua, 5, 91))
>a : Symbol(a, Decl(tluaMetatableOperators.tlua, 6, 18))
>x : Symbol(x, Decl(tluaMetatableOperators.tlua, 6, 22))
>b : Symbol(b, Decl(tluaMetatableOperators.tlua, 6, 35))
>x : Symbol(x, Decl(tluaMetatableOperators.tlua, 6, 40))
>a.x : Symbol(x, Decl(tluaMetatableOperators.tlua, 6, 22))
>a : Symbol(a, Decl(tluaMetatableOperators.tlua, 6, 18))
>x : Symbol(x, Decl(tluaMetatableOperators.tlua, 6, 22))
>b.x : Symbol(x, Decl(tluaMetatableOperators.tlua, 6, 40))
