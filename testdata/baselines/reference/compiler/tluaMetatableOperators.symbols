  __unm = function(a: { x: number }): { x: number } return a; end,
>__unm : Symbol(__unm, Decl(tluaMetatableOperators.tlua, 8, 66))
>a : Symbol(a, Decl(tluaMetatableOperators.tlua, 9, 19))
