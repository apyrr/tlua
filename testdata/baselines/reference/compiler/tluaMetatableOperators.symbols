local w = setmetatable({ x = 2 }, Ops);
>w : Symbol(w, Decl(tluaMetatableOperators.tlua, 14, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>x : Symbol(x, Decl(tluaMetatableOperators.tlua, 14, 24))
