  __le = function(a: { x: number }, b: { x: number }): boolean return a.x <= b.x; end,
>__le : Symbol(__le, Decl(tluaMetatableOperators.tlua, 6, 85))
>a : Symbol(a, Decl(tluaMetatableOperators.tlua, 7, 18))
