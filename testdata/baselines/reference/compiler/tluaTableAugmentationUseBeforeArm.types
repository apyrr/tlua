//// [tests/cases/compiler/tluaTableAugmentationUseBeforeArm.tlua] ////

=== tluaTableAugmentationUseBeforeArm.tlua ===
// Augmentation is resolved at initialization, so a member's type exists
// program-wide; flow analysis then decides what each read sees.

// A read before the global's only constructor arm is flagged as
// used-before-assigned rather than silently typed from the future write.
local beforeArm = Early.member;
>beforeArm : number
>Early.member : number
>Early : { member: number; }
>member : number

Early = {};
>Early = {} : { member: number; }
>Early : { member: number; }
>{} : { member: number; }

Early.member = 1;
>Early.member = 1 : 1
>Early.member : number
>Early : { member: number; }
>member : number
>1 : 1

local afterArm: number = Early.member;
>afterArm : number
>Early.member : number
>Early : { member: number; }
>member : number

// A read between the constructor arm and the member write is not flagged:
// once the table exists, the member read sees the merged member type.
Mid = {};
>Mid = {} : { value: string; }
>Mid : { value: string; }
>{} : { value: string; }

local betweenWrites = Mid.value;
>betweenWrites : string
>Mid.value : string
>Mid : { value: string; }
>value : string

Mid.value = "v";
>Mid.value = "v" : "v"
>Mid.value : string
>Mid : { value: string; }
>value : string
>"v" : "v"

local afterWrite: string = Mid.value;
>afterWrite : string
>Mid.value : string
>Mid : { value: string; }
>value : string

// Same shape on a local table.
local t = {};
>t : { flag: boolean; }
>{} : { flag: boolean; }

local beforeLocalWrite = t.flag;
>beforeLocalWrite : boolean
>t.flag : boolean
>t : { flag: boolean; }
>flag : boolean

t.flag = true;
>t.flag = true : true
>t.flag : boolean
>t : { flag: boolean; }
>flag : boolean
>true : true

local afterLocalWrite: boolean = t.flag;
>afterLocalWrite : boolean
>t.flag : true
>t : { flag: boolean; }
>flag : true

