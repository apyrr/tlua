//// [tests/cases/compiler/tluaIfElseifChain.tlua] ////

=== tluaIfElseifChain.tlua ===
function classify(n: number): string
>classify : Symbol(classify, Decl(tluaIfElseifChain.tlua, 0, 0))
>n : Symbol(n, Decl(tluaIfElseifChain.tlua, 0, 18))

  if n < 0 then
>n : Symbol(n, Decl(tluaIfElseifChain.tlua, 0, 18))

    return "neg";
  elseif n == 0 then
>n : Symbol(n, Decl(tluaIfElseifChain.tlua, 0, 18))

    return "zero";
  elseif n < 10 then
>n : Symbol(n, Decl(tluaIfElseifChain.tlua, 0, 18))

    return "small";
  else
    return "big";
  end
end

// `else` holding a nested full if takes its own end (two ends total).
function elseNestedIf(a: boolean, b: boolean): number
>elseNestedIf : Symbol(elseNestedIf, Decl(tluaIfElseifChain.tlua, 10, 3))
>a : Symbol(a, Decl(tluaIfElseifChain.tlua, 13, 22))
>b : Symbol(b, Decl(tluaIfElseifChain.tlua, 13, 33))

  if a then
>a : Symbol(a, Decl(tluaIfElseifChain.tlua, 13, 22))

    return 1;
  else
    if b then
>b : Symbol(b, Decl(tluaIfElseifChain.tlua, 13, 33))

      return 2;
    end
    return 3;
  end
end

// elseif without a final else.
function noFinalElse(n: number): number
>noFinalElse : Symbol(noFinalElse, Decl(tluaIfElseifChain.tlua, 22, 3))
>n : Symbol(n, Decl(tluaIfElseifChain.tlua, 25, 21))

  if n == 1 then
>n : Symbol(n, Decl(tluaIfElseifChain.tlua, 25, 21))

    return 10;
  elseif n == 2 then
>n : Symbol(n, Decl(tluaIfElseifChain.tlua, 25, 21))

    return 20;
  end
  return 0;
end

