// Exact arity.
local a, b = pair();
>a : Symbol(a, Decl(tluaLocalMultiNameDeclarations.tlua, 12, 5))
>b : Symbol(b, Decl(tluaLocalMultiNameDeclarations.tlua, 12, 8))
>pair : Symbol(pair, Decl(tluaLocalMultiNameDeclarations.tlua, 0, 0))

// More names than values: the extras read as nil.
local c, d, e = pair();
>c : Symbol(c, Decl(tluaLocalMultiNameDeclarations.tlua, 15, 5))
>d : Symbol(d, Decl(tluaLocalMultiNameDeclarations.tlua, 15, 8))
>e : Symbol(e, Decl(tluaLocalMultiNameDeclarations.tlua, 15, 11))
>pair : Symbol(pair, Decl(tluaLocalMultiNameDeclarations.tlua, 0, 0))

// A non-tail call truncates to one value; the tail expands.
local f, g, h = pair(), pair();
>f : Symbol(f, Decl(tluaLocalMultiNameDeclarations.tlua, 18, 5))
>g : Symbol(g, Decl(tluaLocalMultiNameDeclarations.tlua, 18, 8))
>h : Symbol(h, Decl(tluaLocalMultiNameDeclarations.tlua, 18, 11))
>pair : Symbol(pair, Decl(tluaLocalMultiNameDeclarations.tlua, 0, 0))
>pair : Symbol(pair, Decl(tluaLocalMultiNameDeclarations.tlua, 0, 0))

// Plain positional values.
local i, j = 1, "x";
>i : Symbol(i, Decl(tluaLocalMultiNameDeclarations.tlua, 21, 5))
>j : Symbol(j, Decl(tluaLocalMultiNameDeclarations.tlua, 21, 8))

// More values than names: extra values are evaluated and dropped.
local k = 1, "dropped";
>k : Symbol(k, Decl(tluaLocalMultiNameDeclarations.tlua, 24, 5))

// A variadic tail covers all remaining names.
local l, m, n = variadic();
>l : Symbol(l, Decl(tluaLocalMultiNameDeclarations.tlua, 27, 5))
>m : Symbol(m, Decl(tluaLocalMultiNameDeclarations.tlua, 27, 8))
>n : Symbol(n, Decl(tluaLocalMultiNameDeclarations.tlua, 27, 11))
>variadic : Symbol(variadic, Decl(tluaLocalMultiNameDeclarations.tlua, 2, 3))

// A void call provides no values.
local o, q = nothing();
>o : Symbol(o, Decl(tluaLocalMultiNameDeclarations.tlua, 30, 5))
>q : Symbol(q, Decl(tluaLocalMultiNameDeclarations.tlua, 30, 8))
>nothing : Symbol(nothing, Decl(tluaLocalMultiNameDeclarations.tlua, 6, 3))

// No value list at all.
local r, s;
>r : Symbol(r, Decl(tluaLocalMultiNameDeclarations.tlua, 33, 5))
>s : Symbol(s, Decl(tluaLocalMultiNameDeclarations.tlua, 33, 8))

