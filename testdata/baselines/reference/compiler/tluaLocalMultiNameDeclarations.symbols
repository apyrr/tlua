function pair(): (number, string)
>pair : Symbol(pair, Decl(tluaLocalMultiNameDeclarations.tlua, 0, 0))

  return 1, "a";
end

function variadic(): (number, ...string)
>variadic : Symbol(variadic, Decl(tluaLocalMultiNameDeclarations.tlua, 2, 3))

  return 1, "a", "b";
end

function nothing(): void
>nothing : Symbol(nothing, Decl(tluaLocalMultiNameDeclarations.tlua, 6, 3))

