//// [tests/cases/compiler/tluaTableShorthandRemoved.tlua] ////

=== tluaTableShorthandRemoved.tlua ===
// TS object shorthand is gone: `{x}` is a positional entry `[1] = x`.
local x = 1;
>x : number
>1 : 1

local t = { x };
>t : { 1: number; }
>{ x } : { 1: number; }
>x : any

local t1: number = t[1];
>t1 : number
>t[1] : number
>t : { 1: number; }
>1 : 1

// ... so it is not assignable where a property `x` is required.
local s: { x: number } = { x };
>s : { x: number; }
>x : number
>{ x } : { 1: number; }
>x : any

local es = {t1, s};
>es : { 1: number; 2: { x: number; }; }
>{t1, s} : { 1: number; 2: { x: number; }; }
>t1 : any
>s : any

// Destructuring assignment is gone with it: an object literal on the left of
// `=` is an ordinary (erroneous) assignment target ...
declare obj: { q: number; w?: number };
>obj : { q: number; w?: number; }
>q : number
>w : number | nil

local q: number;
>q : number

({ q } = obj);
>({ q } = obj) : { q: number; w?: number; }
>{ q } = obj : { q: number; w?: number; }
>{ q } : { 1: number; }
>q : any
>obj : { q: number; w?: number; }

// ... and `{ w = 5 }` has exactly one meaning -- a Lua keyed field -- so the
// old cover-grammar destructuring reading is an error too.
local w: number | nil;
>w : number | nil

({ w = 5 } = obj);
>({ w = 5 } = obj) : { q: number; w?: number; }
>{ w = 5 } = obj : { q: number; w?: number; }
>{ w = 5 } : { w: number; }
>w : number
>5 : 5
>obj : { q: number; w?: number; }

// Lua spells the extraction with member access ...
local q3 = obj.q;
>q3 : number
>obj.q : number
>obj : { q: number; w?: number; }
>q : number

// ... and parameter binding patterns are a separate grammar, untouched.
function take({ q: q4 }: { q: number }): number { return q4; }
>take : ({ q: q4 }: { q: number; }) => number
>q : any
>q4 : number
>q : number
>q4 : number

local all = {q, w, q3, take};
>all : { 1: number; 2: number | nil; 3: number; 4: ({ q: q4 }: { q: number; }) => number; }
>{q, w, q3, take} : { 1: number; 2: number | nil; 3: number; 4: ({ q: q4 }: { q: number; }) => number; }
>q : any
>w : any
>q3 : any
>take : any

// `export {x}` is different syntax, untouched.
{ x };
>x : number

