    return table[1];
>table : Symbol(table, Decl(tluaTableType.tlua, 79, 9))
>1 : Symbol(1, Decl(tluaTableType.tlua, 79, 19))

end

// `object` is just an identifier now, in both value and type positions.
local dead = object;
>dead : Symbol(dead, Decl(tluaTableType.tlua, 84, 5))

type Obj = object;
>Obj : Symbol(Obj, Decl(tluaTableType.tlua, 84, 20))
>object : Symbol(object)

// The JS Object/Function stubs are gone from the libs entirely.
type O2 = Object;
