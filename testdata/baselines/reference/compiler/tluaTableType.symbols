>Object : Symbol(Object)

type F2 = Function;
>F2 : Symbol(F2, Decl(tluaTableType.tlua, 88, 17))
>Function : Symbol(Function)

// `type(x) == "function"` on unknown narrows to function (the stand-in when
// there is no declared constituent to keep).
declare u: unknown;
>u : Symbol(u, Decl(tluaTableType.tlua, 93, 7))

if type(u) == "function" then
>type : Symbol(type, Decl(lib.luajit.d.tlua, --, --))
>u : Symbol(u, Decl(tluaTableType.tlua, 93, 7))

    local lf2: function = u;
>lf2 : Symbol(lf2, Decl(tluaTableType.tlua, 95, 9))
>u : Symbol(u, Decl(tluaTableType.tlua, 93, 7))

end

