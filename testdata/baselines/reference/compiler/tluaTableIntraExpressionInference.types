//// [tests/cases/compiler/tluaTableIntraExpressionInference.tlua] ////

=== tluaTableIntraExpressionInference.tlua ===
// A context-sensitive function expression in LAST positional-entry position
// must register an intra-expression inference site like any other entry: its
// inferred type fixes T for context-sensitive consumers checked later in the
// same containing expression. The and/or chain is the standard Lua ternary
// idiom, so "later in the same expression" is ordinary code. A member's
// position in the table must not decide whether it participates.
declare function pick<T>(t: { 1: (n: number) => T } | ((v: T) => void)): void;
>pick : <T>(t: { 1: (n: number) => T; } | ((v: T) => void)) => void
>t : { 1: (n: number) => T; } | ((v: T) => void)
>1 : (n: number) => T
>n : number
>v : T

declare function pick2<T>(t: { 1: (n: number) => T, 2?: string } | ((v: T) => void)): void;
>pick2 : <T>(t: { 1: (n: number) => T; 2?: string; } | ((v: T) => void)) => void
>t : { 1: (n: number) => T; 2?: string; } | ((v: T) => void)
>1 : (n: number) => T
>n : number
>2 : string | nil
>v : T

declare cond: boolean;
>cond : boolean

// The producer entry is last (and the table's only entry): T infers number,
// so the consumer's `v` is number.
pick((cond and { function(n) return n; end }) or function(v)
>pick((cond and { function(n) return n; end }) or function(v)  local ok: number = v;end) : void
>pick : <T>(t: { 1: (n: number) => T; } | ((v: T) => void)) => void
>(cond and { function(n) return n; end }) or function(v)  local ok: number = v;end : { 1: (n: number) => number; } | ((v: number) => void)
>(cond and { function(n) return n; end }) : false | { 1: (n: number) => number; }
>cond and { function(n) return n; end } : false | { 1: (n: number) => number; }
>cond : boolean
>{ function(n) return n; end } : { 1: (n: number) => number; }
>function(n) return n; end : (n: number) => number
>n : number
>n : number
>function(v)  local ok: number = v;end : (v: number) => void
>v : number

  local ok: number = v;
>ok : number
>v : number

end);

// Control: the same producer in non-last position behaves identically.
pick2((cond and { function(n) return n; end, "pad" }) or function(v)
>pick2((cond and { function(n) return n; end, "pad" }) or function(v)  local ok: number = v;end) : void
>pick2 : <T>(t: { 1: (n: number) => T; 2?: string; } | ((v: T) => void)) => void
>(cond and { function(n) return n; end, "pad" }) or function(v)  local ok: number = v;end : { 1: (n: number) => number; 2: string; } | ((v: number) => void)
>(cond and { function(n) return n; end, "pad" }) : false | { 1: (n: number) => number; 2: string; }
>cond and { function(n) return n; end, "pad" } : false | { 1: (n: number) => number; 2: string; }
>cond : boolean
>{ function(n) return n; end, "pad" } : { 1: (n: number) => number; 2: string; }
>function(n) return n; end : (n: number) => number
>n : number
>n : number
>function(v)  local ok: number = v;end : (v: number) => void
>v : number

  local ok: number = v;
>ok : number
>v : number

end);

