// A dotted declaration may not redeclare a field written in the table itself.
local Clash = { run = 1 };
>Clash : { run: number; }
>{ run = 1 } : { run: number; }
>run : number
>1 : 1

function Clash.run(): void
>Clash : { run: number; }
