>A : Symbol(A, Decl(tluaTupleTypes.tlua, 105, 23))
>B : Symbol(B, Decl(tluaTupleTypes.tlua, 105, 25))
>A : Symbol(A, Decl(tluaTupleTypes.tlua, 105, 23))

local inferred: string = first({"x", 10});
>inferred : Symbol(inferred, Decl(tluaTupleTypes.tlua, 106, 5))
>first : Symbol(first, Decl(tluaTupleTypes.tlua, 102, 56))

// Variadic composition and indexed access.
type Concat<A extends unknown[], B extends unknown[]> = [...A, ...B];
>Concat : Symbol(Concat, Decl(tluaTupleTypes.tlua, 106, 42))
>A : Symbol(A, Decl(tluaTupleTypes.tlua, 109, 12))
>B : Symbol(B, Decl(tluaTupleTypes.tlua, 109, 32))
>A : Symbol(A, Decl(tluaTupleTypes.tlua, 109, 12))
>B : Symbol(B, Decl(tluaTupleTypes.tlua, 109, 32))

local cat: Concat<[1, 2], [3]> = {1, 2, 3};
>cat : Symbol(cat, Decl(tluaTupleTypes.tlua, 110, 5))
>Concat : Symbol(Concat, Decl(tluaTupleTypes.tlua, 106, 42))

type Second<T extends [unknown, unknown, ...unknown[]]> = T[2];
>Second : Symbol(Second, Decl(tluaTupleTypes.tlua, 110, 43))
>T : Symbol(T, Decl(tluaTupleTypes.tlua, 111, 12))
>T : Symbol(T, Decl(tluaTupleTypes.tlua, 111, 12))

local second: Second<Pair> = 5;
