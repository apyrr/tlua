// Mapped types walk tuples element-wise with 1-based key literals.
type Boxed<T> = { [K in keyof T]: { value: T[K] } };
>Boxed : Symbol(Boxed, Decl(tluaTupleTypes.tlua, 112, 31))
>T : Symbol(T, Decl(tluaTupleTypes.tlua, 115, 11))
>K : Symbol(K, Decl(tluaTupleTypes.tlua, 115, 19))
>T : Symbol(T, Decl(tluaTupleTypes.tlua, 115, 11))
>value : Symbol(value, Decl(tluaTupleTypes.tlua, 115, 35))
>T : Symbol(T, Decl(tluaTupleTypes.tlua, 115, 11))
>K : Symbol(K, Decl(tluaTupleTypes.tlua, 115, 19))

local boxed: Boxed<Pair> = { {value = "a"}, {value = 2} };
>boxed : Symbol(boxed, Decl(tluaTupleTypes.tlua, 116, 5))
>Boxed : Symbol(Boxed, Decl(tluaTupleTypes.tlua, 112, 31))
>Pair : Symbol(Pair, Decl(tluaTupleTypes.tlua, 0, 0))
>value : Symbol(value, Decl(tluaTupleTypes.tlua, 116, 30))
>value : Symbol(value, Decl(tluaTupleTypes.tlua, 116, 45))

