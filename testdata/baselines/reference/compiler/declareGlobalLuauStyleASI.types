//// [tests/cases/compiler/declareGlobalLuauStyleASI.tlua] ////

=== declareGlobalLuauStyleASI.tlua ===
// `declare` remains a valid identifier: without a same-line `name:` it is an
// expression, and a line break after `declare` splits it into two statements.
local declare = 1;
>declare : number
>1 : 1

local x = 2;
>x : number
>2 : 2

declare
>declare : number

x;
>x : number

declare = x;
>declare = x : number
>declare : number
>x : number

local call = function(declare: number) return declare end;
>call : (declare: number) => number
>function(declare: number) return declare end : (declare: number) => number
>declare : number
>declare : number

call(declare);
>call(declare) : number
>call : (declare: number) => number
>declare : number

