=== tluaMetatableGetmetatable.tlua ===
// getmetatable reads back the metatable a table was paired with, rather than the union its
// declaration has to fall back on.

local Helpers = { describe = function(self: table): string return "d"; end };
>Helpers : Symbol(Helpers, Decl(tluaMetatableGetmetatable.tlua, 3, 5))
>describe : Symbol(describe, Decl(tluaMetatableGetmetatable.tlua, 3, 17))
>self : Symbol(self, Decl(tluaMetatableGetmetatable.tlua, 3, 38))

local obj = setmetatable({ n = 1 }, { __index = Helpers });
>obj : Symbol(obj, Decl(tluaMetatableGetmetatable.tlua, 4, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaMetatableGetmetatable.tlua, 4, 26))
>__index : Symbol(__index, Decl(tluaMetatableGetmetatable.tlua, 4, 37))
>Helpers : Symbol(Helpers, Decl(tluaMetatableGetmetatable.tlua, 3, 5))

local mt = getmetatable(obj);
>mt : Symbol(mt, Decl(tluaMetatableGetmetatable.tlua, 6, 5))
>getmetatable : Symbol(getmetatable, Decl(lib.luajit.d.tlua, --, --))
>obj : Symbol(obj, Decl(tluaMetatableGetmetatable.tlua, 4, 5))

local back: string = mt.__index.describe(obj);
