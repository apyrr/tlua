>__luaThreadBrand : Symbol(__luaThreadBrand, Decl(tluaTagPartition.tlua, 12, 20))

declare callableMix: { a: number } & (() => void);
>callableMix : Symbol(callableMix, Decl(tluaTagPartition.tlua, 13, 7))
>a : Symbol(a, Decl(tluaTagPartition.tlua, 13, 22))

declare threadMix: LuaThread & { a: number };
>threadMix : Symbol(threadMix, Decl(tluaTagPartition.tlua, 14, 7))
>LuaThread : Symbol(LuaThread, Decl(lib.luajit.d.tlua, --, --))
>a : Symbol(a, Decl(tluaTagPartition.tlua, 14, 32))

// Column 1: assignable to `table`?
local t1: table = plainTable;
