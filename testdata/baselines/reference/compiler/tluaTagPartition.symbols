//// [tests/cases/compiler/tluaTagPartition.tlua] ////

=== tluaTagPartition.tlua ===
// The runtime-tag partition, locked as one truth table so its three encodings
// (assignability via isLuaTableType, facts via isFunctionObjectType, narrowing
// by tag) cannot drift apart silently. Every value kind is checked against both
// keyword types AND both guards; type() reports exactly one tag per value.

// The kinds under test.
declare plainTable: { n: number };
>plainTable : Symbol(plainTable, Decl(tluaTagPartition.tlua, 6, 7))
>n : Symbol(n, Decl(tluaTagPartition.tlua, 6, 21))

declare fn: () => void;
>fn : Symbol(fn, Decl(tluaTagPartition.tlua, 7, 7))

local pairing = setmetatable({ n = 1 },
>pairing : Symbol(pairing, Decl(tluaTagPartition.tlua, 8, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaTagPartition.tlua, 8, 30))

    { __call = function(self: table, x: number): number return x; end });
>__call : Symbol(__call, Decl(tluaTagPartition.tlua, 9, 5))
>self : Symbol(self, Decl(tluaTagPartition.tlua, 9, 24))
>x : Symbol(x, Decl(tluaTagPartition.tlua, 9, 36))
>x : Symbol(x, Decl(tluaTagPartition.tlua, 9, 36))

declare brandedPrim: string & { tag: number };
>brandedPrim : Symbol(brandedPrim, Decl(tluaTagPartition.tlua, 10, 7))
>tag : Symbol(tag, Decl(tluaTagPartition.tlua, 10, 31))

