//// [tests/cases/compiler/tluaWhileStatement.tlua] ////

=== tluaWhileStatement.tlua ===
function sum(limit: number): number
>sum : (limit: number) => number
>limit : number

  local total = 0;
>total : number
>0 : 0

  local i = 0;
>i : number
>0 : 0

  while i < limit do
>i < limit : boolean
>i : number
>limit : number

    total = total + i;
>total = total + i : number
>total : number
>total + i : number
>total : number
>i : number

    i = i + 1;
>i = i + 1 : number
>i : number
>i + 1 : number
>i : number
>1 : 1

  end
  return total;
>total : number

end

// Parenthesized condition with `do` is Lua.
function parens(flag: boolean): number
>parens : (flag: boolean) => number
>flag : boolean

  local n = 0;
>n : number
>0 : 0

  while (flag) do
>(flag) : boolean
>flag : boolean

    flag = false;
>flag = false : false
>flag : boolean
>false : false

    n = 1;
>n = 1 : 1
>n : number
>1 : 1

  end
  return n;
>n : number

end

// break exits the loop; one-liner bodies parse (ASI before `end`).
function firstOver(limit: number): number
>firstOver : (limit: number) => number
>limit : number

  local i = 0;
>i : number
>0 : 0

  while true do
>true : true

    if i > limit then break end
>i > limit : boolean
>i : number
>limit : number

    i = i + 1;
>i = i + 1 : number
>i : number
>i + 1 : number
>i : number
>1 : 1

  end
  return i;
>i : number

end

// Nested while loops.
function grid(w: number, h: number): number
>grid : (w: number, h: number) => number
>w : number
>h : number

  local count = 0;
>count : number
>0 : 0

  local x = 0;
>x : number
>0 : 0

  while x < w do
>x < w : boolean
>x : number
>w : number

    local y = 0;
>y : number
>0 : 0

    while y < h do
>y < h : boolean
>y : number
>h : number

      count = count + 1;
>count = count + 1 : number
>count : number
>count + 1 : number
>count : number
>1 : 1

      y = y + 1;
>y = y + 1 : number
>y : number
>y + 1 : number
>y : number
>1 : 1

    end
    x = x + 1;
>x = x + 1 : number
>x : number
>x + 1 : number
>x : number
>1 : 1

  end
  return count;
>count : number

end

