=== tluaMultiReturnTypeSyntax.tlua ===
// Bare multi-return type lists on declaration headers.
function pair(): (number, string)
>pair : Symbol(pair, Decl(tluaMultiReturnTypeSyntax.tlua, 0, 0))

  return 1, "a";
end

function triple(): (number, string, boolean)
>triple : Symbol(triple, Decl(tluaMultiReturnTypeSyntax.tlua, 3, 3))

  return 1, "a", true;
end

local function localPair(): (number, string)
>localPair : Symbol(localPair, Decl(tluaMultiReturnTypeSyntax.tlua, 7, 3))

  return 2, "b";
end

function bracePair(): (number, string)
>bracePair : Symbol(bracePair, Decl(tluaMultiReturnTypeSyntax.tlua, 11, 3))

  return 3, "c";
end

local exprPair = function(): (number, string)
>exprPair : Symbol(exprPair, Decl(tluaMultiReturnTypeSyntax.tlua, 17, 5))

  return 4, "d";
end;

// Single-type returns are unchanged by the list grammar.
function single(): number
>single : Symbol(single, Decl(tluaMultiReturnTypeSyntax.tlua, 19, 4))

  return 5;
end

function explicitPair(): (number, string)
>explicitPair : Symbol(explicitPair, Decl(tluaMultiReturnTypeSyntax.tlua, 24, 3))

  return 6, "f";
end

