// Callable types use an explicitly parenthesized return-pack syntax.
type PairFunction = () => (number, string);
>PairFunction : Symbol(PairFunction, Decl(tluaMultiReturnTypeSyntax.tlua, 36, 25))

declare pairFunction: PairFunction;
>pairFunction : Symbol(pairFunction, Decl(tluaMultiReturnTypeSyntax.tlua, 40, 7))
>PairFunction : Symbol(PairFunction, Decl(tluaMultiReturnTypeSyntax.tlua, 36, 25))

local pairAlias: PairFunction = pair;
>pairAlias : Symbol(pairAlias, Decl(tluaMultiReturnTypeSyntax.tlua, 41, 5))
>PairFunction : Symbol(PairFunction, Decl(tluaMultiReturnTypeSyntax.tlua, 36, 25))
>pair : Symbol(pair, Decl(tluaMultiReturnTypeSyntax.tlua, 0, 0))

interface PairCallable {
>PairCallable : Symbol(PairCallable, Decl(tluaMultiReturnTypeSyntax.tlua, 41, 37))

  (): (number, string);
  pair(): (number, string);
