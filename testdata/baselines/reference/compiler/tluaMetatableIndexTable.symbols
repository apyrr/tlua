//// [tests/cases/compiler/tluaMetatableIndexTable.tlua] ////

=== tluaMetatableIndexTable.tlua ===
// setmetatable pairs a table with its metatable: a read the table misses falls through to
// the metatable's __index, so the call cannot keep returning the plain table it was given.

local Helpers = {
>Helpers : Symbol(Helpers, Decl(tluaMetatableIndexTable.tlua, 3, 5))

  describe = function(self: object): string return "d"; end,
>describe : Symbol(describe, Decl(tluaMetatableIndexTable.tlua, 3, 17))
>self : Symbol(self, Decl(tluaMetatableIndexTable.tlua, 4, 22))

  count = 0,
>count : Symbol(count, Decl(tluaMetatableIndexTable.tlua, 4, 60))

};

local mt = { __index = Helpers };
>mt : Symbol(mt, Decl(tluaMetatableIndexTable.tlua, 8, 5))
>__index : Symbol(__index, Decl(tluaMetatableIndexTable.tlua, 8, 12))
>Helpers : Symbol(Helpers, Decl(tluaMetatableIndexTable.tlua, 3, 5))

local obj = setmetatable({ n = 1 }, mt);
>obj : Symbol(obj, Decl(tluaMetatableIndexTable.tlua, 10, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaMetatableIndexTable.tlua, 10, 26))
>mt : Symbol(mt, Decl(tluaMetatableIndexTable.tlua, 8, 5))

// The table's own members stay.
local n: number = obj.n;
>n : Symbol(n, Decl(tluaMetatableIndexTable.tlua, 13, 5))
>obj.n : Symbol(n, Decl(tluaMetatableIndexTable.tlua, 10, 26))
>obj : Symbol(obj, Decl(tluaMetatableIndexTable.tlua, 10, 5))
>n : Symbol(n, Decl(tluaMetatableIndexTable.tlua, 10, 26))

// A missing member is found behind __index.
local d: string = obj.describe(obj);
>d : Symbol(d, Decl(tluaMetatableIndexTable.tlua, 16, 5))
>obj.describe : Symbol(describe, Decl(tluaMetatableIndexTable.tlua, 3, 17))
>obj : Symbol(obj, Decl(tluaMetatableIndexTable.tlua, 10, 5))
>describe : Symbol(describe, Decl(tluaMetatableIndexTable.tlua, 3, 17))
>obj : Symbol(obj, Decl(tluaMetatableIndexTable.tlua, 10, 5))

local c: number = obj.count;
>c : Symbol(c, Decl(tluaMetatableIndexTable.tlua, 17, 5))
>obj.count : Symbol(count, Decl(tluaMetatableIndexTable.tlua, 4, 60))
>obj : Symbol(obj, Decl(tluaMetatableIndexTable.tlua, 10, 5))
>count : Symbol(count, Decl(tluaMetatableIndexTable.tlua, 4, 60))

// What neither has is still missing.
local absent = obj.nothing;
>absent : Symbol(absent, Decl(tluaMetatableIndexTable.tlua, 20, 5))
>obj : Symbol(obj, Decl(tluaMetatableIndexTable.tlua, 10, 5))

// The table wins a collision: a raw read hits it before the metatable ever runs.
local collide = setmetatable({ v = 1 }, { __index = { v = "str" } });
>collide : Symbol(collide, Decl(tluaMetatableIndexTable.tlua, 23, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>v : Symbol(v, Decl(tluaMetatableIndexTable.tlua, 23, 30))
>__index : Symbol(__index, Decl(tluaMetatableIndexTable.tlua, 23, 41))
>v : Symbol(v, Decl(tluaMetatableIndexTable.tlua, 23, 53))

local cn: number = collide.v;
>cn : Symbol(cn, Decl(tluaMetatableIndexTable.tlua, 24, 5))
>collide.v : Symbol(v, Decl(tluaMetatableIndexTable.tlua, 23, 30))
>collide : Symbol(collide, Decl(tluaMetatableIndexTable.tlua, 23, 5))
>v : Symbol(v, Decl(tluaMetatableIndexTable.tlua, 23, 30))

local cs: string = collide.v;
>cs : Symbol(cs, Decl(tluaMetatableIndexTable.tlua, 25, 5))
>collide.v : Symbol(v, Decl(tluaMetatableIndexTable.tlua, 23, 30))
>collide : Symbol(collide, Decl(tluaMetatableIndexTable.tlua, 23, 5))
>v : Symbol(v, Decl(tluaMetatableIndexTable.tlua, 23, 30))

// A fallback member is writable at its own type -- a Lua write raw-sets the table, which
// shadows the metatable's copy from then on.
obj.count = 2;
>obj.count : Symbol(count, Decl(tluaMetatableIndexTable.tlua, 4, 60))
>obj : Symbol(obj, Decl(tluaMetatableIndexTable.tlua, 10, 5))
>count : Symbol(count, Decl(tluaMetatableIndexTable.tlua, 4, 60))

obj.count = "two";
>obj.count : Symbol(count, Decl(tluaMetatableIndexTable.tlua, 4, 60))
>obj : Symbol(obj, Decl(tluaMetatableIndexTable.tlua, 10, 5))
>count : Symbol(count, Decl(tluaMetatableIndexTable.tlua, 4, 60))

// An index signature behind __index carries over.
declare idxMt: { __index: { [key: string]: number } };
>idxMt : Symbol(idxMt, Decl(tluaMetatableIndexTable.tlua, 33, 7))
>__index : Symbol(__index, Decl(tluaMetatableIndexTable.tlua, 33, 16))
