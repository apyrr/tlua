=== tluaTypeCallIfExhaustive.tlua ===
type Mixed = { n: number } | LuaThread | ((a: number) => void) | string | nil;
>Mixed : Mixed
>n : number
>a : number

function clauses(v: Mixed): string
>clauses : (v: Mixed) => string
>v : Mixed

  if type(v) == "string" then
>type(v) == "string" : boolean
>type(v) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>v : Mixed
>"string" : "string"

    local s: string = v;
>s : string
>v : string

    return s;
>s : string

  elseif type(v) == "table" or type(v) == "function" then
>type(v) == "table" or type(v) == "function" : boolean
>type(v) == "table" : boolean
>type(v) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>v : LuaThread | { n: number; } | ((a: number) => void) | nil
>"table" : "table"
>type(v) == "function" : boolean
>type(v) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>v : LuaThread | ((a: number) => void) | nil
>"function" : "function"

    // An or-grouped condition narrows to the union of its tags.
    local tf: { n: number } | ((a: number) => void) = v;
>tf : { n: number; } | ((a: number) => void)
>n : number
>a : number
>v : { n: number; } | ((a: number) => void)

    return "tf";
>"tf" : "tf"

  elseif type(v) == "thread" then
>type(v) == "thread" : boolean
>type(v) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>v : LuaThread | nil
>"thread" : "thread"

    local th: LuaThread = v;
>th : LuaThread
>v : LuaThread

    return "thread";
>"thread" : "thread"

  else
    // The final else is left with what no other arm handled.
    local rest: nil = v;
>rest : nil
>v : nil

    return "nil";
>"nil" : "nil"

  end
end

// Handling every tag in arms without a final else still leaves the fall-out
// path: the exhaustive-switch return inference did not survive switch's
// deletion, so the return type gains nil.
function allTagsNoElse(u: unknown)
>allTagsNoElse : (u: unknown) => 1 | 2 | 3 | 4 | 5 | 6 | 7 | 8 | 9 | nil
>u : unknown

  if type(u) == "nil" then return 1
>type(u) == "nil" : boolean
>type(u) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
