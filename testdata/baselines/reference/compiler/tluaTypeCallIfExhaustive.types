>u : {}
>"number" : "number"
>3 : 3

  elseif type(u) == "string" then return 4
>type(u) == "string" : boolean
>type(u) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>u : {}
>"string" : "string"
>4 : 4

  elseif type(u) == "table" then return 5
>type(u) == "table" : boolean
>type(u) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>u : {}
>"table" : "table"
>5 : 5

  elseif type(u) == "function" then return 6
>type(u) == "function" : boolean
>type(u) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>u : {}
>"function" : "function"
>6 : 6

  elseif type(u) == "thread" then return 7
>type(u) == "thread" : boolean
>type(u) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>u : {}
>"thread" : "thread"
>7 : 7

  elseif type(u) == "userdata" then return 8
>type(u) == "userdata" : boolean
>type(u) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>u : {}
