//// [tests/cases/compiler/tluaNumberKeyNormalization.tlua] ////

=== tluaNumberKeyNormalization.tlua ===
// Every spelling of a numeric value names the same key.
local t = { [0x10] = "hex", [1e2] = "exp", [1.5] = "frac", [-1] = "neg" };
>t : { 16: string; 100: string; 1.5: string; [-1]: string; }
>{ [0x10] = "hex", [1e2] = "exp", [1.5] = "frac", [-1] = "neg" } : { 16: string; 100: string; 1.5: string; [-1]: string; }
>[0x10] : string
>0x10 : 16
>"hex" : "hex"
>[1e2] : string
>1e2 : 100
>"exp" : "exp"
>[1.5] : string
>1.5 : 1.5
>"frac" : "frac"
>[-1] : string
>-1 : -1
>1 : 1
>"neg" : "neg"

local hex: string = t[16];
>hex : string
>t[16] : string
>t : { 16: string; 100: string; 1.5: string; [-1]: string; }
>16 : 16

local exp: string = t[100];
>exp : string
>t[100] : string
>t : { 16: string; 100: string; 1.5: string; [-1]: string; }
>100 : 100

local frac: string = t[1.5];
>frac : string
>t[1.5] : string
>t : { 16: string; 100: string; 1.5: string; [-1]: string; }
>1.5 : 1.5

local neg: string = t[-1];
>neg : string
>t[-1] : string
>t : { 16: string; 100: string; 1.5: string; [-1]: string; }
>-1 : -1
>1 : 1

local es = {hex, exp, frac, neg};
>es : { 1: string; 2: string; 3: string; 4: string; }
>{hex, exp, frac, neg} : { 1: string; 2: string; 3: string; 4: string; }
>hex : error
>exp : error
>frac : error
>neg : error

