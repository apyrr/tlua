>x : Symbol(x, Decl(tluaNumericFor.tlua, 30, 5))
>w : Symbol(w, Decl(tluaNumericFor.tlua, 28, 16))

    for y = 1, h do
>y : Symbol(y, Decl(tluaNumericFor.tlua, 31, 7))
>h : Symbol(h, Decl(tluaNumericFor.tlua, 28, 26))

      if (count > 100) {
>count : Symbol(count, Decl(tluaNumericFor.tlua, 29, 7))

        break;
