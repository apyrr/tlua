  for i = n, 1, -1 do
>i : Symbol(i, Decl(tluaNumericFor.tlua, 11, 5))
>n : Symbol(n, Decl(tluaNumericFor.tlua, 9, 19))

    last = i;
>last : Symbol(last, Decl(tluaNumericFor.tlua, 10, 7))
>i : Symbol(i, Decl(tluaNumericFor.tlua, 11, 5))

    i = i - 1;
>i : Symbol(i, Decl(tluaNumericFor.tlua, 11, 5))
>i : Symbol(i, Decl(tluaNumericFor.tlua, 11, 5))

  end
  return last;
>last : Symbol(last, Decl(tluaNumericFor.tlua, 10, 7))

end

