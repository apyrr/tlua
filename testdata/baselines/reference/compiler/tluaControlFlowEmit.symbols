// Required values substitute in numeric-for bounds and until-conditions.
function f(): number
>f : Symbol(f, Decl(main.tlua, 1, 28))

  local total = 0;
>total : Symbol(total, Decl(main.tlua, 5, 7))

  for i = 1, N do
>i : Symbol(i, Decl(main.tlua, 6, 5))
>N : Symbol(N, Decl(main.tlua, 1, 5))

    total = total + i;
>total : Symbol(total, Decl(main.tlua, 5, 7))
>total : Symbol(total, Decl(main.tlua, 5, 7))
>i : Symbol(i, Decl(main.tlua, 6, 5))

  end
  repeat
    total = total + 1;
>total : Symbol(total, Decl(main.tlua, 5, 7))
>total : Symbol(total, Decl(main.tlua, 5, 7))

  until done;
>done : Symbol(done, Decl(main.tlua, 1, 8))

  while done do
>done : Symbol(done, Decl(main.tlua, 1, 8))

    total = total - 1;
>total : Symbol(total, Decl(main.tlua, 5, 7))
>total : Symbol(total, Decl(main.tlua, 5, 7))

  end
  return total;
>total : Symbol(total, Decl(main.tlua, 5, 7))

end

