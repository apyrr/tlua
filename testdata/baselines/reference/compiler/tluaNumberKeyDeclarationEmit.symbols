//// [tests/cases/compiler/tluaNumberKeyDeclarationEmit.tlua] ////

=== defs.d.tlua ===
// A hand-written declaration file: 1 is a number key, "1" a string key.
declare d: { 1: number; "1": string };
>d : Symbol(d, Decl(defs.d.tlua, 1, 7))
>1 : Symbol(1, Decl(defs.d.tlua, 1, 12))
>"1" : Symbol("1", Decl(defs.d.tlua, 1, 23))

=== main.tlua ===
local dn: number = d[1];
>dn : Symbol(dn, Decl(main.tlua, 0, 5))
>d : Symbol(d, Decl(defs.d.tlua, 1, 7))
>1 : Symbol(1, Decl(defs.d.tlua, 1, 12))

local ds: string = d["1"];
>ds : Symbol(ds, Decl(main.tlua, 1, 5))
>d : Symbol(d, Decl(defs.d.tlua, 1, 7))
>"1" : Symbol("1", Decl(defs.d.tlua, 1, 23))

// Number and string keys stay distinct in source table types too.
local t = { [1] = 1, ["1"] = "s", x = true };
>t : Symbol(t, Decl(main.tlua, 4, 5))
>[1] : Symbol([1], Decl(main.tlua, 4, 11))
>1 : Symbol([1], Decl(main.tlua, 4, 11))
>["1"] : Symbol(["1"], Decl(main.tlua, 4, 20))
>"1" : Symbol(["1"], Decl(main.tlua, 4, 20))
>x : Symbol(x, Decl(main.tlua, 4, 33))

local tn: number = t[1];
>tn : Symbol(tn, Decl(main.tlua, 5, 5))
>t : Symbol(t, Decl(main.tlua, 4, 5))
>1 : Symbol([1], Decl(main.tlua, 4, 11))

local ts: string = t["1"];
>ts : Symbol(ts, Decl(main.tlua, 6, 5))
>t : Symbol(t, Decl(main.tlua, 4, 5))
>"1" : Symbol(["1"], Decl(main.tlua, 4, 20))

return { t = t, dn = dn, ds = ds, tn = tn, ts = ts };
>t : Symbol(t, Decl(main.tlua, 7, 8))
>t : Symbol(t, Decl(main.tlua, 4, 5))
>dn : Symbol(dn, Decl(main.tlua, 7, 15))
>dn : Symbol(dn, Decl(main.tlua, 0, 5))
>ds : Symbol(ds, Decl(main.tlua, 7, 24))
>ds : Symbol(ds, Decl(main.tlua, 1, 5))
>tn : Symbol(tn, Decl(main.tlua, 7, 33))
>tn : Symbol(tn, Decl(main.tlua, 5, 5))
>ts : Symbol(ts, Decl(main.tlua, 7, 42))
>ts : Symbol(ts, Decl(main.tlua, 6, 5))

