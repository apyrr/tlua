=== tluaTypeCallNarrowing.tlua ===
// `type(x)` is the Lua type guard. Every tag it can return narrows, including the
// three branded non-table kinds, which carry the same type facts as a plain table and
// therefore cannot be told apart by facts alone.

type Mixed = { n: number } | thread | userdata | cdata | ((a: number) => void) | string | number | boolean | nil;
