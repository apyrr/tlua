=== tluaMetatableGeneric.tlua ===
// A pairing resolves its members eagerly, so it can only hold concrete types. A generic
// table falls back to the intersection, which is less precise about collisions but does
// instantiate -- the same trade a generic spread makes.

local helpers = { describe = function(self: object): string return "d"; end };
>helpers : Symbol(helpers, Decl(tluaMetatableGeneric.tlua, 4, 5))
>describe : Symbol(describe, Decl(tluaMetatableGeneric.tlua, 4, 17))
>self : Symbol(self, Decl(tluaMetatableGeneric.tlua, 4, 38))

function withHelpers<T extends object>(value: T)
>withHelpers : Symbol(withHelpers, Decl(tluaMetatableGeneric.tlua, 4, 78))
>T : Symbol(T, Decl(tluaMetatableGeneric.tlua, 6, 21))
>value : Symbol(value, Decl(tluaMetatableGeneric.tlua, 6, 39))
>T : Symbol(T, Decl(tluaMetatableGeneric.tlua, 6, 21))

  return setmetatable(value, { __index = helpers });
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>value : Symbol(value, Decl(tluaMetatableGeneric.tlua, 6, 39))
>__index : Symbol(__index, Decl(tluaMetatableGeneric.tlua, 7, 30))
