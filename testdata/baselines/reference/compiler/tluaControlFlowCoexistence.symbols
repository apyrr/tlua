//// [tests/cases/compiler/tluaControlFlowCoexistence.tlua] ////

=== tluaControlFlowCoexistence.tlua ===
// Lua control-flow forms parse and emit.
function ifForms(flag: boolean): number
>ifForms : Symbol(ifForms, Decl(tluaControlFlowCoexistence.tlua, 0, 0))
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 1, 17))

  if flag then
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 1, 17))

    return 1;
  end
  if flag then return 2 end
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 1, 17))

  if flag then return 3 else return 4 end
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 1, 17))

  return 0;
end

// Loop forms, including a repeat/until standing in for the old do-while.
function loopForms(flag: boolean): number
>loopForms : Symbol(loopForms, Decl(tluaControlFlowCoexistence.tlua, 8, 3))
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 11, 19))

  while flag do
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 11, 19))

    flag = false;
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 11, 19))

  end
  repeat
    flag = false;
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 11, 19))

  until not (flag)
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 11, 19))

  return 0;
end

// Nested control flow.
function nested(flag: boolean): number
>nested : Symbol(nested, Decl(tluaControlFlowCoexistence.tlua, 19, 3))
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 22, 16))

  if flag then
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 22, 16))

    if flag then
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 22, 16))

      return 1;
    end
  end
  while flag do
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 22, 16))

    while flag do
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 22, 16))

      flag = false;
>flag : Symbol(flag, Decl(tluaControlFlowCoexistence.tlua, 22, 16))

    end
  end
  return 0;
end

