//// [tests/cases/compiler/tluaIfElseifChain.tlua] ////

=== tluaIfElseifChain.tlua ===
function classify(n: number): string
>classify : (n: number) => string
>n : number

  if n < 0 then
>n < 0 : boolean
>n : number
>0 : 0

    return "neg";
>"neg" : "neg"

  elseif n == 0 then
>n == 0 : boolean
>n : number
>0 : 0

    return "zero";
>"zero" : "zero"

  elseif n < 10 then
>n < 10 : boolean
>n : number
>10 : 10

    return "small";
>"small" : "small"

  else
    return "big";
>"big" : "big"

  end
end

// `else` holding a nested full if takes its own end (two ends total).
function elseNestedIf(a: boolean, b: boolean): number
>elseNestedIf : (a: boolean, b: boolean) => number
>a : boolean
>b : boolean

  if a then
>a : boolean

    return 1;
>1 : 1

  else
    if b then
>b : boolean

      return 2;
>2 : 2

    end
    return 3;
>3 : 3

  end
end

// elseif without a final else.
function noFinalElse(n: number): number
>noFinalElse : (n: number) => number
>n : number

  if n == 1 then
>n == 1 : boolean
>n : number
>1 : 1

    return 10;
>10 : 10

  elseif n == 2 then
>n == 2 : boolean
>n : number
>2 : 2

    return 20;
>20 : 20

  end
  return 0;
>0 : 0

end

