>inferredUnionOfPacks : Symbol(inferredUnionOfPacks, Decl(tluaVarargAdjustment.tlua, 134, 3))
>b : Symbol(b, Decl(tluaVarargAdjustment.tlua, 140, 30))
> : Symbol((Missing), Decl(tluaVarargAdjustment.tlua, 140, 41))

  if b then
>b : Symbol(b, Decl(tluaVarargAdjustment.tlua, 140, 30))

    return 1, ...;
  end
  return "a";
end

