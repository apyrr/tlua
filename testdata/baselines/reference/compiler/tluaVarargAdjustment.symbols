function tailIntoParameters(...: number): void
>tailIntoParameters : Symbol(tailIntoParameters, Decl(tluaVarargAdjustment.tlua, 47, 65))
> : Symbol((Missing), Decl(tluaVarargAdjustment.tlua, 49, 28))

  // Every parameter the tail reaches may go without a value, so each receives
  // `number | nil` -- which is exactly what makes these legal without a special
  // case for optional parameters.
  optionalOnly(...);
>optionalOnly : Symbol(optionalOnly, Decl(tluaVarargAdjustment.tlua, 43, 3))

  trailingOptional(1, ...);
>trailingOptional : Symbol(trailingOptional, Decl(tluaVarargAdjustment.tlua, 45, 48))

  // A rest parameter absorbs whatever is left, however little, so it receives
  // the element type unchanged -- no nil, no arity check.
  takesNumbers(...);
>takesNumbers : Symbol(takesNumbers, Decl(tluaVarargAdjustment.tlua, 0, 0))

  leadingFixed("x", ...);
>leadingFixed : Symbol(leadingFixed, Decl(tluaVarargAdjustment.tlua, 46, 63))

  // But a fixed parameter ahead of the rest is still a fixed parameter.
  leadingFixed(...);
>leadingFixed : Symbol(leadingFixed, Decl(tluaVarargAdjustment.tlua, 46, 63))

end

