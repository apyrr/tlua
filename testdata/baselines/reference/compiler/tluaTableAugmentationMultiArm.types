//// [tests/cases/compiler/tluaTableAugmentationMultiArm.tlua] ////

=== a.tlua ===
V = {};
>V = {} : { m: string; }
>V : { m: string; } | { m: string; b: number; }
>{} : { m: string; }

V.m = "s";
>V.m = "s" : "s"
>V.m : string
>V : { m: string; }
>m : string
>"s" : "s"

local va: string = V.m;
>va : string
>V.m : string
>V : { m: string; }
>m : string

=== b.tlua ===
