//// [tests/cases/compiler/tluaMetatableStatement.tlua] ////

=== tluaMetatableStatement.tlua ===
// `setmetatable(t, mt);` as a statement -- how Lua actually attaches a metatable, mutating in
// place -- narrows its table operand to the paired type, the way an assertion narrows its
// argument.

local Helpers = { describe = function(self: table): string return "d"; end };
>Helpers : { describe: (self: table) => string; }
>{ describe = function(self: table): string return "d"; end } : { describe: (self: table) => string; }
>describe : (self: table) => string
>function(self: table): string return "d"; end : (self: table) => string
>self : table
>"d" : "d"

local Counters = { count = function(self: table): number return 1; end };
>Counters : { count: (self: table) => number; }
>{ count = function(self: table): number return 1; end } : { count: (self: table) => number; }
>count : (self: table) => number
>function(self: table): number return 1; end : (self: table) => number
>self : table
>1 : 1

local mt = { __index = Helpers };
>mt : { __index: { describe: (self: table) => string; }; }
>{ __index = Helpers } : { __index: { describe: (self: table) => string; }; }
>__index : { describe: (self: table) => string; }
>Helpers : { describe: (self: table) => string; }

local mt2 = { __index = Counters };
>mt2 : { __index: { count: (self: table) => number; }; }
>{ __index = Counters } : { __index: { count: (self: table) => number; }; }
>__index : { count: (self: table) => number; }
>Counters : { count: (self: table) => number; }

function basic(): void
>basic : () => void

  local t = { n = 1 };
>t : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  setmetatable(t, mt);
>setmetatable(t, mt) : { describe: (self: table) => string; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

  local d: string = t.describe(t);  // the fallback is visible after the statement
>d : string
>t.describe(t) : string
>t.describe : (self: table) => string
>t : { describe: (self: table) => string; n: number; }
>describe : (self: table) => string
>t : { describe: (self: table) => string; n: number; }

  local n: number = t.n;            // the own member is intact
>n : number
>t.n : number
>t : { describe: (self: table) => string; n: number; }
>n : number

end

function replaced(): void
>replaced : () => void

  local t = { n = 1 };
>t : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  setmetatable(t, mt);
>setmetatable(t, mt) : { describe: (self: table) => string; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

  setmetatable(t, mt2);             // replacement: unpair, then re-pair
>setmetatable(t, mt2) : { count: (self: table) => number; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { describe: (self: table) => string; n: number; }
>mt2 : { __index: { count: (self: table) => number; }; }

  local c: number = t.count(t);
>c : number
>t.count(t) : number
>t.count : (self: table) => number
>t : { count: (self: table) => number; n: number; }
>count : (self: table) => number
>t : { count: (self: table) => number; n: number; }

  local gone = t.describe;          // the old pairing is gone
>gone : any
>t.describe : any
>t : { count: (self: table) => number; n: number; }
>describe : any

end

function detached(): void
>detached : () => void

  local t = { n = 1 };
>t : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  setmetatable(t, mt);
>setmetatable(t, mt) : { describe: (self: table) => string; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

  setmetatable(t, nil);             // nil detaches
>setmetatable(t, nil) : { n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { describe: (self: table) => string; n: number; }

  local gone = t.describe;
>gone : any
>t.describe : any
>t : { n: number; }
>describe : any

end

function invalidated(): void
>invalidated : () => void

  local t = { n = 1 };
>t : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  setmetatable(t, mt);
>setmetatable(t, mt) : { describe: (self: table) => string; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

  t = { n = 2 };                    // an assignment kills the narrowing
>t = { n = 2 } : { n: number; }
>t : { n: number; }
>{ n = 2 } : { n: number; }
>n : number
>2 : 2

  local gone = t.describe;
>gone : any
>t.describe : any
>t : { n: number; }
>describe : any

end

function inLoop(cond: boolean): void
>inLoop : (cond: boolean) => void
>cond : boolean

  local t = { n = 1 };
>t : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  while cond do
>cond : boolean

    setmetatable(t, mt);
>setmetatable(t, mt) : { describe: (self: table) => string; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

    local d: string = t.describe(t);
>d : string
>t.describe(t) : string
>t.describe : (self: table) => string
>t : { describe: (self: table) => string; n: number; }
>describe : (self: table) => string
>t : { describe: (self: table) => string; n: number; }

  end
  local gone = t.describe;          // the never-ran arm keeps t unpaired
>gone : any
>t.describe : any
>t : { n: number; }
>describe : any

end

function inConditional(cond: boolean): void
>inConditional : (cond: boolean) => void
>cond : boolean

  local t = { n = 1 };
>t : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  if cond then
>cond : boolean

    setmetatable(t, mt);
>setmetatable(t, mt) : { describe: (self: table) => string; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

    local d: string = t.describe(t);
>d : string
>t.describe(t) : string
>t.describe : (self: table) => string
>t : { describe: (self: table) => string; n: number; }
>describe : (self: table) => string
>t : { describe: (self: table) => string; n: number; }

  end
  local gone = t.describe;          // the join keeps the unpaired arm
>gone : any
>t.describe : any
>t : { n: number; }
>describe : any

end

function propertyTarget(): void
>propertyTarget : () => void

  local holder = { field = { n = 1 } };
>holder : { field: { n: number; }; }
>{ field = { n = 1 } } : { field: { n: number; }; }
>field : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  setmetatable(holder.field, mt);   // a property-access target narrows too
>setmetatable(holder.field, mt) : { describe: (self: table) => string; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>holder.field : { n: number; }
>holder : { field: { n: number; }; }
>field : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

  local d: string = holder.field.describe(holder.field);
>d : string
>holder.field.describe(holder.field) : string
>holder.field.describe : (self: table) => string
>holder.field : { describe: (self: table) => string; n: number; }
>holder : { field: { n: number; }; }
>field : { describe: (self: table) => string; n: number; }
>describe : (self: table) => string
>holder.field : { describe: (self: table) => string; n: number; }
>holder : { field: { n: number; }; }
>field : { describe: (self: table) => string; n: number; }

end

function shadowed(): void
>shadowed : () => void

  local setmetatable = function(value: table, metatable: table): table return value; end;
>setmetatable : (value: table, metatable: table) => table
>function(value: table, metatable: table): table return value; end : (value: table, metatable: table) => table
>value : table
>metatable : table
>value : table

  local t = { n = 1 };
>t : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  setmetatable(t, mt);              // not the global, so no narrowing
>setmetatable(t, mt) : table
>setmetatable : (value: table, metatable: table) => table
>t : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

  local gone = t.describe;
>gone : any
>t.describe : any
>t : { n: number; }
>describe : any

end

