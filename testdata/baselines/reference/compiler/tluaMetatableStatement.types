>constCapture : () => void

  local t = { n = 1 };
>t : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  setmetatable(t, mt);
>setmetatable(t, mt) : { describe: (self: table) => string; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

  local f = function(): void
>f : () => void
>function(): void    // t is never reassigned, so the narrowing reaches into the closure, as an assertion's does.    local d: string = t.describe(t);  end : () => void

    // t is never reassigned, so the narrowing reaches into the closure, as an assertion's does.
    local d: string = t.describe(t);
>d : string
>t.describe(t) : string
>t.describe : (self: table) => string
>t : { describe: (self: table) => string; n: number; }
