function assignForm(): void
>assignForm : () => void

  local t = { n = 1 };
>t : { n: number; }
>{ n = 1 } : { n: number; }
>n : number
>1 : 1

  local r = setmetatable(t, mt);    // the assign form types the result, not the argument
>r : { describe: (self: table) => string; n: number; }
>setmetatable(t, mt) : { describe: (self: table) => string; n: number; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { n: number; }
>mt : { __index: { describe: (self: table) => string; }; }

  local rd: string = r.describe(r);
>rd : string
>r.describe(r) : string
>r.describe : (self: table) => string
>r : { describe: (self: table) => string; n: number; }
>describe : (self: table) => string
>r : { describe: (self: table) => string; n: number; }

  local gone = t.describe;
>gone : any
>t.describe : any
>t : { n: number; }
>describe : any

end

// The metatable argument references the table through the same statement, inside a loop: the
// re-entrancy must terminate (the inner query simply sees the unpaired table).
function selfReferential(cond: boolean): void
>selfReferential : (cond: boolean) => void
>cond : boolean

  local t = { n = 1, mt = mt };
>t : { n: number; mt: { __index: { describe: (self: table) => string; }; }; }
>{ n = 1, mt = mt } : { n: number; mt: { __index: { describe: (self: table) => string; }; }; }
>n : number
>1 : 1
>mt : { __index: { describe: (self: table) => string; }; }
>mt : { __index: { describe: (self: table) => string; }; }

  while cond do
>cond : boolean

    setmetatable(t, t.mt);
>setmetatable(t, t.mt) : { describe: (self: table) => string; n: number; mt: { __index: { describe: (self: table) => string; }; }; }
>setmetatable : <T extends table>(value: T, metatable: LuaMetatable<T> | nil) => T
>t : { n: number; mt: { __index: { describe: (self: table) => string; }; }; }
>t.mt : { __index: { describe: (self: table) => string; }; }
>t : { n: number; mt: { __index: { describe: (self: table) => string; }; }; }
>mt : { __index: { describe: (self: table) => string; }; }

  end
  local after: number = t.n;
>after : number
>t.n : number
>t : { n: number; mt: { __index: { describe: (self: table) => string; }; }; }
>n : number

end

