// The first name drops nil (a nil first value ends the loop); the second
// keeps the iterator's declared nil-ability and narrows normally.
function walk(t: string[]): number
>walk : Symbol(walk, Decl(tluaGenericFor.tlua, 1, 58))
>t : Symbol(t, Decl(tluaGenericFor.tlua, 5, 14))

  local count = 0;
>count : Symbol(count, Decl(tluaGenericFor.tlua, 6, 7))

  for i, s in ipairsLike(t) do
>i : Symbol(i, Decl(tluaGenericFor.tlua, 7, 5))
>s : Symbol(s, Decl(tluaGenericFor.tlua, 7, 8))
>ipairsLike : Symbol(ipairsLike, Decl(tluaGenericFor.tlua, 0, 69))
>t : Symbol(t, Decl(tluaGenericFor.tlua, 5, 14))

    count = count + i;
>count : Symbol(count, Decl(tluaGenericFor.tlua, 6, 7))
>count : Symbol(count, Decl(tluaGenericFor.tlua, 6, 7))
>i : Symbol(i, Decl(tluaGenericFor.tlua, 7, 5))

    if s ~= nil then
>s : Symbol(s, Decl(tluaGenericFor.tlua, 7, 8))

      count = count + s.length;
>count : Symbol(count, Decl(tluaGenericFor.tlua, 6, 7))
>count : Symbol(count, Decl(tluaGenericFor.tlua, 6, 7))
>s.length : Symbol(String.length, Decl(lib.luajit.d.tlua, --, --))
>s : Symbol(s, Decl(tluaGenericFor.tlua, 7, 8))
>length : Symbol(String.length, Decl(lib.luajit.d.tlua, --, --))

    end
  end
  return count;
>count : Symbol(count, Decl(tluaGenericFor.tlua, 6, 7))

end

