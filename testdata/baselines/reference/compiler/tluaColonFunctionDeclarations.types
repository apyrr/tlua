// A colon method still reaches the table's other members through `self`.
function M:double(): number
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; double(self: any): number; }
>double : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; double(self: any): number; }) => number
>: : { count: number; inc(self: any, by: number): number; read(self: any): number; double(self: any): number; }
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; double(self: any): number; }

  return self.inc(self, self.read(self));
>self.inc(self, self.read(self)) : number
