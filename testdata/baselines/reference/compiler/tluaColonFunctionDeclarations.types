>M : { count: number; inc(self: any, by: number): number; read(self: any): number; double(self: any): number; }
>by : number

  self.count = self.count + by;
>self.count = self.count + by : number
>self.count : number
>self : { count: number; inc(self: any, by: number): number; read(self: any): number; double(self: any): number; }
>count : number
>self.count + by : number
>self.count : number
>self : { count: number; inc(self: any, by: number): number; read(self: any): number; double(self: any): number; }
>count : number
>by : number

  return self.count;
>self.count : number
>self : { count: number; inc(self: any, by: number): number; read(self: any): number; double(self: any): number; }
