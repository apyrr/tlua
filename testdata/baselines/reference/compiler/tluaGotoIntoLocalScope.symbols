//// [tests/cases/compiler/tluaGotoIntoLocalScope.tlua] ////

=== tluaGotoIntoLocalScope.tlua ===
// Error: `x` is still in scope at ::done::, so the jump enters its scope.
function intoScope(): number
>intoScope : Symbol(intoScope, Decl(tluaGotoIntoLocalScope.tlua, 0, 0))

    goto done
    local x = 1;
>x : Symbol(x, Decl(tluaGotoIntoLocalScope.tlua, 3, 9))

    ::done::
    return x;
>x : Symbol(x, Decl(tluaGotoIntoLocalScope.tlua, 3, 9))

end

// Error: a `local function` declares a local too.
function intoFunctionScope(): void
>intoFunctionScope : Symbol(intoFunctionScope, Decl(tluaGotoIntoLocalScope.tlua, 6, 3))

    goto done
    local function helper(): void
>helper : Symbol(helper, Decl(tluaGotoIntoLocalScope.tlua, 10, 13))

    end
    ::done::
    helper();
>helper : Symbol(helper, Decl(tluaGotoIntoLocalScope.tlua, 10, 13))

end

// Accepted: the label sits in the block's trailing void region, where no local
// is in scope. This is the relaxation that makes the skip-to-end idiom legal.
function trailingLabel(): void
>trailingLabel : Symbol(trailingLabel, Decl(tluaGotoIntoLocalScope.tlua, 15, 3))

    goto done
    local x = 1;
>x : Symbol(x, Decl(tluaGotoIntoLocalScope.tlua, 21, 9))

    ::done::
end

// Accepted: a local inside a nested block died with that block.
function subBlockLocal(): void
>subBlockLocal : Symbol(subBlockLocal, Decl(tluaGotoIntoLocalScope.tlua, 23, 3))

    goto done
    do
        local x = 1;
>x : Symbol(x, Decl(tluaGotoIntoLocalScope.tlua, 29, 13))

    end
    ::done::
    return;
end

// Error: a multi-name local declares every binding at once, so jumping past it
// enters their scope. The message names the first binding.
function intoMultiNameScope(): number
>intoMultiNameScope : Symbol(intoMultiNameScope, Decl(tluaGotoIntoLocalScope.tlua, 33, 3))

    goto done
    local a, b = 1, 2;
>a : Symbol(a, Decl(tluaGotoIntoLocalScope.tlua, 39, 9))
>b : Symbol(b, Decl(tluaGotoIntoLocalScope.tlua, 39, 12))

    ::done::
    return b;
>b : Symbol(b, Decl(tluaGotoIntoLocalScope.tlua, 39, 12))

end

// Accepted: a backward jump leaves scopes, it never enters one.
function backwardPastLocal(): void
>backwardPastLocal : Symbol(backwardPastLocal, Decl(tluaGotoIntoLocalScope.tlua, 42, 3))

    ::top::
    local x = 1;
>x : Symbol(x, Decl(tluaGotoIntoLocalScope.tlua, 47, 9))

    if x < 5 then goto top end
>x : Symbol(x, Decl(tluaGotoIntoLocalScope.tlua, 47, 9))

end

// Accepted: the loop body's trailing label, jumped to past the body's local.
function skipToEnd(n: number): number
>skipToEnd : Symbol(skipToEnd, Decl(tluaGotoIntoLocalScope.tlua, 49, 3))
>n : Symbol(n, Decl(tluaGotoIntoLocalScope.tlua, 52, 19))

    local total = 0;
>total : Symbol(total, Decl(tluaGotoIntoLocalScope.tlua, 53, 9))

    while n > 0 do
>n : Symbol(n, Decl(tluaGotoIntoLocalScope.tlua, 52, 19))

        n = n - 1;
>n : Symbol(n, Decl(tluaGotoIntoLocalScope.tlua, 52, 19))
>n : Symbol(n, Decl(tluaGotoIntoLocalScope.tlua, 52, 19))

        if n == 3 then goto next end
>n : Symbol(n, Decl(tluaGotoIntoLocalScope.tlua, 52, 19))

        local step = n * 2;
>step : Symbol(step, Decl(tluaGotoIntoLocalScope.tlua, 57, 13))
>n : Symbol(n, Decl(tluaGotoIntoLocalScope.tlua, 52, 19))

        total = total + step;
>total : Symbol(total, Decl(tluaGotoIntoLocalScope.tlua, 53, 9))
>total : Symbol(total, Decl(tluaGotoIntoLocalScope.tlua, 53, 9))
>step : Symbol(step, Decl(tluaGotoIntoLocalScope.tlua, 57, 13))

        ::next::
    end
    return total;
>total : Symbol(total, Decl(tluaGotoIntoLocalScope.tlua, 53, 9))

end

