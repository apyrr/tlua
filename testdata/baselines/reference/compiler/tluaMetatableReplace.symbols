>rm : Symbol(rm, Decl(tluaMetatableReplace.tlua, 28, 5))
>__index : Symbol(__index, Decl(tluaMetatableReplace.tlua, 10, 36))
>fromSecond : Symbol(fromSecond, Decl(tluaMetatableReplace.tlua, 5, 16))

// The statement form -- how Lua mutates a table in place -- narrows the variable, so its
// fallback is visible afterward. (tluaMetatableStatement covers this in full.)
local plain = { n = 1 };
>plain : Symbol(plain, Decl(tluaMetatableReplace.tlua, 33, 5))
>n : Symbol(n, Decl(tluaMetatableReplace.tlua, 33, 15))

setmetatable(plain, { __index = First });
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>plain : Symbol(plain, Decl(tluaMetatableReplace.tlua, 33, 5))
>__index : Symbol(__index, Decl(tluaMetatableReplace.tlua, 34, 21))
>First : Symbol(First, Decl(tluaMetatableReplace.tlua, 4, 5))

local statementForm: boolean = plain.fromFirst;
