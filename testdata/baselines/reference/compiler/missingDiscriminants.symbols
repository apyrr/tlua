//// [tests/cases/compiler/missingDiscriminants.tlua] ////

=== missingDiscriminants.tlua ===
// https://github.com/microsoft/typescript-go/issues/1020

type Thing =
>Thing : Symbol(Thing, Decl(missingDiscriminants.tlua, 0, 0))

  | { str: "a", num: 0 }
>str : Symbol(str, Decl(missingDiscriminants.tlua, 3, 5))
>num : Symbol(num, Decl(missingDiscriminants.tlua, 3, 15))

  | { str: "b" }
>str : Symbol(str, Decl(missingDiscriminants.tlua, 4, 5))

  | { num: 1 }
>num : Symbol(num, Decl(missingDiscriminants.tlua, 5, 5))

local thing1: Thing = { str = "a", num = 0 }
>thing1 : Symbol(thing1, Decl(missingDiscriminants.tlua, 7, 5))
>Thing : Symbol(Thing, Decl(missingDiscriminants.tlua, 0, 0))
>str : Symbol(str, Decl(missingDiscriminants.tlua, 7, 23))
>num : Symbol(num, Decl(missingDiscriminants.tlua, 7, 34))

local thing2: Thing = { str = "b", num = 1 } // Shouldn't be error
>thing2 : Symbol(thing2, Decl(missingDiscriminants.tlua, 8, 5))
>Thing : Symbol(Thing, Decl(missingDiscriminants.tlua, 0, 0))
>str : Symbol(str, Decl(missingDiscriminants.tlua, 8, 23))
>num : Symbol(num, Decl(missingDiscriminants.tlua, 8, 34))

local thing3: Thing = { num = 1, str = "b" } // Shouldn't be error
>thing3 : Symbol(thing3, Decl(missingDiscriminants.tlua, 9, 5))
>Thing : Symbol(Thing, Decl(missingDiscriminants.tlua, 0, 0))
>num : Symbol(num, Decl(missingDiscriminants.tlua, 9, 23))
>str : Symbol(str, Decl(missingDiscriminants.tlua, 9, 32))

type Item =
>Item : Symbol(Item, Decl(missingDiscriminants.tlua, 9, 44))

  | { kind: "a", subkind: 0, value: string }
>kind : Symbol(kind, Decl(missingDiscriminants.tlua, 12, 5))
>subkind : Symbol(subkind, Decl(missingDiscriminants.tlua, 12, 16))
>value : Symbol(value, Decl(missingDiscriminants.tlua, 12, 28))

  | { kind: "a", subkind: 1, value: number }
>kind : Symbol(kind, Decl(missingDiscriminants.tlua, 13, 5))
>subkind : Symbol(subkind, Decl(missingDiscriminants.tlua, 13, 16))
>value : Symbol(value, Decl(missingDiscriminants.tlua, 13, 28))

  | { kind: "b" }
>kind : Symbol(kind, Decl(missingDiscriminants.tlua, 14, 5))

local item1: Item = { subkind = 1, kind = "b" } // Error, type "b" not assignable to type "a"
>item1 : Symbol(item1, Decl(missingDiscriminants.tlua, 16, 5))
>Item : Symbol(Item, Decl(missingDiscriminants.tlua, 9, 44))
>subkind : Symbol(subkind, Decl(missingDiscriminants.tlua, 16, 21))
>kind : Symbol(kind, Decl(missingDiscriminants.tlua, 16, 34))

local item2: Item = { kind = "b", subkind = 1 } // Error, 'subkind' isn't a known property
>item2 : Symbol(item2, Decl(missingDiscriminants.tlua, 17, 5))
>Item : Symbol(Item, Decl(missingDiscriminants.tlua, 9, 44))
>kind : Symbol(kind, Decl(missingDiscriminants.tlua, 17, 21))
>subkind : Symbol(subkind, Decl(missingDiscriminants.tlua, 17, 33))

