//// [tests/cases/compiler/templateLiteralMultiByteCharInference.tlua] ////

=== templateLiteralMultiByteCharInference.tlua ===
// Verifies that template literal type inference handles multi-byte characters correctly,
// slicing by Unicode code point (rune) instead of by byte.

type GetFirst<S extends string> = S extends `${infer Head}${string}` ? Head : never;
>GetFirst : Symbol(GetFirst, Decl(templateLiteralMultiByteCharInference.tlua, 0, 0))
>S : Symbol(S, Decl(templateLiteralMultiByteCharInference.tlua, 3, 14))
>S : Symbol(S, Decl(templateLiteralMultiByteCharInference.tlua, 3, 14))
>Head : Symbol(Head, Decl(templateLiteralMultiByteCharInference.tlua, 3, 52))
>Head : Symbol(Head, Decl(templateLiteralMultiByteCharInference.tlua, 3, 52))

type GetRest<S extends string> = S extends `${string}${infer Rest}` ? Rest : never;
>GetRest : Symbol(GetRest, Decl(templateLiteralMultiByteCharInference.tlua, 3, 84))
>S : Symbol(S, Decl(templateLiteralMultiByteCharInference.tlua, 4, 13))
>S : Symbol(S, Decl(templateLiteralMultiByteCharInference.tlua, 4, 13))
>Rest : Symbol(Rest, Decl(templateLiteralMultiByteCharInference.tlua, 4, 60))
>Rest : Symbol(Rest, Decl(templateLiteralMultiByteCharInference.tlua, 4, 60))

type Split<S extends string> = S extends `${infer Head}${infer Rest}` ? [Head, Rest] : never;
>Split : Symbol(Split, Decl(templateLiteralMultiByteCharInference.tlua, 4, 83))
>S : Symbol(S, Decl(templateLiteralMultiByteCharInference.tlua, 5, 11))
>S : Symbol(S, Decl(templateLiteralMultiByteCharInference.tlua, 5, 11))
>Head : Symbol(Head, Decl(templateLiteralMultiByteCharInference.tlua, 5, 49))
>Rest : Symbol(Rest, Decl(templateLiteralMultiByteCharInference.tlua, 5, 62))
>Head : Symbol(Head, Decl(templateLiteralMultiByteCharInference.tlua, 5, 49))
>Rest : Symbol(Rest, Decl(templateLiteralMultiByteCharInference.tlua, 5, 62))

// Single-byte (ASCII) characters
type A = GetFirst<"ABC">;  // "A"
>A : Symbol(A, Decl(templateLiteralMultiByteCharInference.tlua, 5, 93))
>GetFirst : Symbol(GetFirst, Decl(templateLiteralMultiByteCharInference.tlua, 0, 0))

type BC = GetRest<"ABC">;  // "BC"
>BC : Symbol(BC, Decl(templateLiteralMultiByteCharInference.tlua, 8, 25))
>GetRest : Symbol(GetRest, Decl(templateLiteralMultiByteCharInference.tlua, 3, 84))

type ABC_Split = Split<"ABC">;  // ["A", "BC"]
>ABC_Split : Symbol(ABC_Split, Decl(templateLiteralMultiByteCharInference.tlua, 9, 25))
>Split : Symbol(Split, Decl(templateLiteralMultiByteCharInference.tlua, 4, 83))

// Multi-byte characters (Japanese, 3 bytes in UTF-8, 1 code unit in UTF-16)
type Ah = GetFirst<"あいう">;  // "あ"
>Ah : Symbol(Ah, Decl(templateLiteralMultiByteCharInference.tlua, 10, 30))
>GetFirst : Symbol(GetFirst, Decl(templateLiteralMultiByteCharInference.tlua, 0, 0))

type IU = GetRest<"あいう">;  // "いう"
>IU : Symbol(IU, Decl(templateLiteralMultiByteCharInference.tlua, 13, 26))
>GetRest : Symbol(GetRest, Decl(templateLiteralMultiByteCharInference.tlua, 3, 84))

type AIU_Split = Split<"あいう">;  // ["あ", "いう"]
>AIU_Split : Symbol(AIU_Split, Decl(templateLiteralMultiByteCharInference.tlua, 14, 25))
>Split : Symbol(Split, Decl(templateLiteralMultiByteCharInference.tlua, 4, 83))

// Mixed single-byte and multi-byte
type M1 = GetFirst<"aあ">;  // "a"
>M1 : Symbol(M1, Decl(templateLiteralMultiByteCharInference.tlua, 15, 30))
>GetFirst : Symbol(GetFirst, Decl(templateLiteralMultiByteCharInference.tlua, 0, 0))

type M2 = GetFirst<"あa">;  // "あ"
>M2 : Symbol(M2, Decl(templateLiteralMultiByteCharInference.tlua, 18, 25))
>GetFirst : Symbol(GetFirst, Decl(templateLiteralMultiByteCharInference.tlua, 0, 0))

// 2-byte UTF-8 characters (Latin Extended, 1 code unit in UTF-16)
type E = GetFirst<"éàü">;  // "é"
>E : Symbol(E, Decl(templateLiteralMultiByteCharInference.tlua, 19, 25))
>GetFirst : Symbol(GetFirst, Decl(templateLiteralMultiByteCharInference.tlua, 0, 0))

// Emoji (4 bytes in UTF-8, 2 code units in UTF-16 as surrogate pair)
type Emoji = GetFirst<"😀abc">;
>Emoji : Symbol(Emoji, Decl(templateLiteralMultiByteCharInference.tlua, 22, 25))
>GetFirst : Symbol(GetFirst, Decl(templateLiteralMultiByteCharInference.tlua, 0, 0))

// Verification
type Expect<T, Expected> = T extends Expected ? true : false;
>Expect : Symbol(Expect, Decl(templateLiteralMultiByteCharInference.tlua, 25, 31))
>T : Symbol(T, Decl(templateLiteralMultiByteCharInference.tlua, 28, 12))
>Expected : Symbol(Expected, Decl(templateLiteralMultiByteCharInference.tlua, 28, 14))
>T : Symbol(T, Decl(templateLiteralMultiByteCharInference.tlua, 28, 12))
