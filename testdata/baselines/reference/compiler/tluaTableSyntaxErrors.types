//// [tests/cases/compiler/tluaTableSyntaxErrors.tlua] ////

=== tluaTableSyntaxErrors.tlua ===
// Missing values: natural expression-expected errors.
local a = { x = };
>a : { x: any; }
>{ x = } : { x: any; }
>x : any
> : any

local b = { ["k"] = };
>b : { k: any; }
>{ ["k"] = } : { k: any; }
>["k"] : any
>"k" : "k"
> : any

// Literal string/number keys must use the bracket form (`["s"] = 1`,
// `[1] = 2`): a bare string/number key is a natural recovery error.
local c = { "s" = 1 };
>c : { 1: number; }
>{ "s" = 1 } : { 1: number; }
>"s" = 1 : 1
>"s" : "s"
>1 : 1

local d = { 1 = 2 };
>d : { 1: number; }
>{ 1 = 2 } : { 1: number; }
>1 = 2 : 2
>1 : 1
>2 : 2

// Stray separators: natural recovery errors.
local e = { ; };
>e : {}
>{ ; } : {}

local f = { g = 1;; h = 2 };
>f : { g: number; h: number; }
>{ g = 1;; h = 2 } : { g: number; h: number; }
>g : number
>1 : 1
>h : number
>2 : 2

