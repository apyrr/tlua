// __index declared optional strips its nil arm: what is left names one fallback.
declare optional: { __index?: { a: number } };
>optional : Symbol(optional, Decl(tluaMetatableImprecise.tlua, 37, 7))
>__index : Symbol(__index, Decl(tluaMetatableImprecise.tlua, 37, 19))
