>noIndex : Symbol(noIndex, Decl(tluaMetatableImprecise.tlua, 27, 5))
>n : Symbol(n, Decl(tluaMetatableImprecise.tlua, 27, 30))

// A callable table would be indexed by Lua, but which half answers a read is not worth
// guessing at.
declare hybrid: { __index: { (t: object, k: any): string; extra: number } };
>hybrid : Symbol(hybrid, Decl(tluaMetatableImprecise.tlua, 32, 7))
>__index : Symbol(__index, Decl(tluaMetatableImprecise.tlua, 32, 17))
>t : Symbol(t, Decl(tluaMetatableImprecise.tlua, 32, 30))
>k : Symbol(k, Decl(tluaMetatableImprecise.tlua, 32, 40))
>extra : Symbol(extra, Decl(tluaMetatableImprecise.tlua, 32, 57))

local h = setmetatable({ n = 1 }, hybrid);
>h : Symbol(h, Decl(tluaMetatableImprecise.tlua, 33, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaMetatableImprecise.tlua, 33, 24))
