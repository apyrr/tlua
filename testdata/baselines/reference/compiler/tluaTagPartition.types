if type(uBranded) == "function" then local g4: never = uBranded; end
>type(uBranded) == "function" : boolean
>type(uBranded) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>uBranded : number | (string & { tag: number; })
>"function" : "function"
>g4 : never
>uBranded : never

if type(uThread) == "function" then local g5: never = uThread; end
>type(uThread) == "function" : boolean
>type(uThread) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>uThread : number | LuaThread
>"function" : "function"
>g5 : never
>uThread : never

if type(uLookalike) == "function" then local g6: never = uLookalike; end
>type(uLookalike) == "function" : boolean
>type(uLookalike) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>uLookalike : number | { __luaThreadBrand: number; }
>"function" : "function"
>g6 : never
>uLookalike : never

if type(uCallableMix) == "function" then uCallableMix(); end
>type(uCallableMix) == "function" : boolean
>type(uCallableMix) : "boolean" | "cdata" | "function" | "nil" | "number" | "string" | "table" | "thread" | "userdata"
>type : (value: any) => "nil" | "number" | "string" | "boolean" | "table" | "function" | "thread" | "userdata" | "cdata"
>uCallableMix : number | ({ a: number; } & (() => void))
>"function" : "function"
>uCallableMix() : void
>uCallableMix : { a: number; } & (() => void)

if type(uThreadMix) == "function" then local g8: never = uThreadMix; end
>type(uThreadMix) == "function" : boolean
