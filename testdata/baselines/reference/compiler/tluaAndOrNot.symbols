//// [tests/cases/compiler/tluaAndOrNot.tlua] ////

=== tluaAndOrNot.tlua ===
// `and`, `or` and `not` are Lua's spellings of `&&`, `||` and `!`. They are
// aliases -- the same token kinds -- so the two spellings parse, check and emit
// identically, and the words are canonical on the way out. `not` is the one
// exception: its token kind is shared with the non-null and definite-assignment
// `!`, which must stay punctuation, so `not x` emits as `!x`.

declare s: string;
>s : Symbol(s, Decl(tluaAndOrNot.tlua, 6, 7))

declare n: number;
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))

declare b: boolean;
>b : Symbol(b, Decl(tluaAndOrNot.tlua, 8, 7))

declare maybe: string | nil;
>maybe : Symbol(maybe, Decl(tluaAndOrNot.tlua, 9, 7))

// Both spellings, same meaning.
local w1 = s and n;
>w1 : Symbol(w1, Decl(tluaAndOrNot.tlua, 12, 5))
>s : Symbol(s, Decl(tluaAndOrNot.tlua, 6, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))

local p1 = s && n;
>p1 : Symbol(p1, Decl(tluaAndOrNot.tlua, 13, 5))
>s : Symbol(s, Decl(tluaAndOrNot.tlua, 6, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))

local w2 = s or n;
>w2 : Symbol(w2, Decl(tluaAndOrNot.tlua, 14, 5))
>s : Symbol(s, Decl(tluaAndOrNot.tlua, 6, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))

local p2 = s || n;
>p2 : Symbol(p2, Decl(tluaAndOrNot.tlua, 15, 5))
>s : Symbol(s, Decl(tluaAndOrNot.tlua, 6, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))

local w3 = not b;
>w3 : Symbol(w3, Decl(tluaAndOrNot.tlua, 16, 5))
>b : Symbol(b, Decl(tluaAndOrNot.tlua, 8, 7))

local p3 = !b;
>p3 : Symbol(p3, Decl(tluaAndOrNot.tlua, 17, 5))
>b : Symbol(b, Decl(tluaAndOrNot.tlua, 8, 7))

// Mixed within one expression.
local m1 = (s and n) || (n and s);
>m1 : Symbol(m1, Decl(tluaAndOrNot.tlua, 19, 5))
>s : Symbol(s, Decl(tluaAndOrNot.tlua, 6, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>s : Symbol(s, Decl(tluaAndOrNot.tlua, 6, 7))

local m2 = not b && b;
>m2 : Symbol(m2, Decl(tluaAndOrNot.tlua, 20, 5))
>b : Symbol(b, Decl(tluaAndOrNot.tlua, 8, 7))
>b : Symbol(b, Decl(tluaAndOrNot.tlua, 8, 7))

// Precedence agrees between the languages: comparison binds tighter than `and`,
// which binds tighter than `or`. All four spell the same tree.
local prec1 = n > 1 and n < 5 or b;
>prec1 : Symbol(prec1, Decl(tluaAndOrNot.tlua, 24, 5))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>b : Symbol(b, Decl(tluaAndOrNot.tlua, 8, 7))

local prec2 = n > 1 && n < 5 || b;
>prec2 : Symbol(prec2, Decl(tluaAndOrNot.tlua, 25, 5))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>b : Symbol(b, Decl(tluaAndOrNot.tlua, 8, 7))

local prec3 = (n > 1 and n < 5) or b;
>prec3 : Symbol(prec3, Decl(tluaAndOrNot.tlua, 26, 5))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>b : Symbol(b, Decl(tluaAndOrNot.tlua, 8, 7))

local prec4 = ((n > 1) && (n < 5)) || b;
>prec4 : Symbol(prec4, Decl(tluaAndOrNot.tlua, 27, 5))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>n : Symbol(n, Decl(tluaAndOrNot.tlua, 7, 7))
>b : Symbol(b, Decl(tluaAndOrNot.tlua, 8, 7))

// `not` does not disturb the other uses of `!`.
local nonNull = maybe!.length;
>nonNull : Symbol(nonNull, Decl(tluaAndOrNot.tlua, 30, 5))
>maybe!.length : Symbol(String.length, Decl(lib.luajit.d.tlua, --, --))
>maybe : Symbol(maybe, Decl(tluaAndOrNot.tlua, 9, 7))
>length : Symbol(String.length, Decl(lib.luajit.d.tlua, --, --))

local doubleNot = not not maybe;
>doubleNot : Symbol(doubleNot, Decl(tluaAndOrNot.tlua, 31, 5))
>maybe : Symbol(maybe, Decl(tluaAndOrNot.tlua, 9, 7))

// Optional chaining lowers to an `and`-guard.
local chain = maybe?.length;
>chain : Symbol(chain, Decl(tluaAndOrNot.tlua, 34, 5))
>maybe?.length : Symbol(String.length, Decl(lib.luajit.d.tlua, --, --))
>maybe : Symbol(maybe, Decl(tluaAndOrNot.tlua, 9, 7))
>length : Symbol(String.length, Decl(lib.luajit.d.tlua, --, --))

// The words are reserved, so a table key must be quoted, as in Lua.
declare t: { [k: string]: number };
>t : Symbol(t, Decl(tluaAndOrNot.tlua, 37, 7))
>k : Symbol(k, Decl(tluaAndOrNot.tlua, 37, 14))

local byIndex = t["and"];
>byIndex : Symbol(byIndex, Decl(tluaAndOrNot.tlua, 38, 5))
>t : Symbol(t, Decl(tluaAndOrNot.tlua, 37, 7))

local byIndex2 = t["or"];
>byIndex2 : Symbol(byIndex2, Decl(tluaAndOrNot.tlua, 39, 5))
>t : Symbol(t, Decl(tluaAndOrNot.tlua, 37, 7))

local byIndex3 = t["not"];
>byIndex3 : Symbol(byIndex3, Decl(tluaAndOrNot.tlua, 40, 5))
>t : Symbol(t, Decl(tluaAndOrNot.tlua, 37, 7))

