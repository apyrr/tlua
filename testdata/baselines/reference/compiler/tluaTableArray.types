//// [tests/cases/compiler/tluaTableArray.tlua] ////

=== tluaTableArray.tlua ===
// Positional entries: keys 1..n, exactly as if written `[i] = v`.
local a = { 1, 2, 3 };
>a : { 1: number; 2: number; 3: number; }
>{ 1, 2, 3 } : { 1: number; 2: number; 3: number; }

local a1: number = a[1];
>a1 : number
>a[1] : number
>a : { 1: number; 2: number; 3: number; }
>1 : 1

local a3: number = a[3];
>a3 : number
>a[3] : number
>a : { 1: number; 2: number; 3: number; }
>3 : 3

// Equivalence with explicit bracket keys.
local b = { [1] = 1, [2] = 2, [3] = 3 };
>b : { 1: number; 2: number; 3: number; }
>{ [1] = 1, [2] = 2, [3] = 3 } : { 1: number; 2: number; 3: number; }
>[1] : number
>1 : 1
>1 : 1
>[2] : number
>2 : 2
>2 : 2
>[3] : number
>3 : 3
>3 : 3

local eq: typeof b = a;
>eq : { 1: number; 2: number; 3: number; }
>b : { 1: number; 2: number; 3: number; }
>a : { 1: number; 2: number; 3: number; }

local es = {a1, a3, eq};
>es : { 1: number; 2: number; 3: { 1: number; 2: number; 3: number; }; }
>{a1, a3, eq} : { 1: number; 2: number; 3: { 1: number; 2: number; 3: number; }; }
>a1 : error
>a3 : error
>eq : error

// Element types are per-position, like `[i] = v`.
local mixed = { 1, "two", true };
>mixed : { 1: number; 2: string; 3: boolean; }
>{ 1, "two", true } : { 1: number; 2: string; 3: boolean; }
>true : true

local m1: number = mixed[1];
>m1 : number
>mixed[1] : number
>mixed : { 1: number; 2: string; 3: boolean; }
>1 : 1

local m2: string = mixed[2];
>m2 : string
>mixed[2] : string
>mixed : { 1: number; 2: string; 3: boolean; }
>2 : 2

local m3: boolean = mixed[3];
>m3 : boolean
>mixed[3] : boolean
>mixed : { 1: number; 2: string; 3: boolean; }
>3 : 3

local ms = {m1, m2, m3};
>ms : { 1: number; 2: string; 3: boolean; }
>{m1, m2, m3} : { 1: number; 2: string; 3: boolean; }
>m1 : error
>m2 : error
>m3 : error

