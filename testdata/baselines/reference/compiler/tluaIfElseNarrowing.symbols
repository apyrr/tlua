// Narrowing persists into while bodies.
function whileNarrow(x: number | nil): number
>whileNarrow : Symbol(whileNarrow, Decl(tluaIfElseNarrowing.tlua, 31, 3))
>x : Symbol(x, Decl(tluaIfElseNarrowing.tlua, 34, 21))

  local total = 0;
>total : Symbol(total, Decl(tluaIfElseNarrowing.tlua, 35, 7))

  while x ~= nil do
>x : Symbol(x, Decl(tluaIfElseNarrowing.tlua, 34, 21))

    total = total + x;
>total : Symbol(total, Decl(tluaIfElseNarrowing.tlua, 35, 7))
>total : Symbol(total, Decl(tluaIfElseNarrowing.tlua, 35, 7))
>x : Symbol(x, Decl(tluaIfElseNarrowing.tlua, 34, 21))

    x = nil;
>x : Symbol(x, Decl(tluaIfElseNarrowing.tlua, 34, 21))

  end
  return total;
>total : Symbol(total, Decl(tluaIfElseNarrowing.tlua, 35, 7))

