>t : Symbol(t, Decl(tluaColonCallBasic.tlua, 31, 5))
>plus : Symbol(plus, Decl(tluaColonCallBasic.tlua, 32, 12))

// A receiver that survived its `?.` guards is not nil at call time: the
// implicit first argument carries the narrowed type, so no spurious mismatch.
local maybe: { inner: typeof M } | nil = { inner = M };
>maybe : Symbol(maybe, Decl(tluaColonCallBasic.tlua, 39, 5))
>inner : Symbol(inner, Decl(tluaColonCallBasic.tlua, 39, 14))
>M : Symbol(M, Decl(tluaColonCallBasic.tlua, 0, 5))
>inner : Symbol(inner, Decl(tluaColonCallBasic.tlua, 39, 42))
>M : Symbol(M, Decl(tluaColonCallBasic.tlua, 0, 5))

local g = maybe?.inner:read();
