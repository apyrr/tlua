// https://github.com/microsoft/TypeScript/issues/63270

type Recur<T> =
>Recur : Recur<T>

    (T extends  (unknown[]) ? {} : { [K in keyof T]?: Recur<T[K]>}) |
    [...Recur<T>[number][]];

function join<T>(l: Recur<T>[]): Recur<T> {
>join : <T>(l: Recur<T>[]) => Recur<T>
>l : Recur<T>[]

    return ['marker', ...l];
>['marker', ... : any
> : any
>'marker', ... : any
>'marker' : "marker"
>... : any
>l : Recur<T>[]
}

function a<T>(l: Recur<T>[]): void {
>a : <T>(l: Recur<T>[]) => void
>l : Recur<T>[]

    local x: Recur<T> | undefined = join(l);
>x : Recur<T> | nil
>join(l) : Recur<T>
>join : <T_1>(l: Recur<T_1>[]) => Recur<T_1>
>l : Recur<T>[]
}

