>{ __index = { swapped = "s" } } : { __index: { swapped: string; }; }
>__index : { swapped: string; }
>{ swapped = "s" } : { swapped: string; }
>swapped : string
>"s" : "s"

  local s: string = prot.swapped;
>s : string
>prot.swapped : string
>prot : { y: number; swapped: string; }
>swapped : string

  local goneBase = prot.base;
>goneBase : any
>prot.base : any
