end

// Duplicate members.
local Dup = {};
>Dup : { f: any; }
>{} : { f: any; }

function Dup.f(): void
>Dup : { f: any; }
>f : any

end

function Dup.f(): void
>Dup : { f: any; }
>f : any

end

