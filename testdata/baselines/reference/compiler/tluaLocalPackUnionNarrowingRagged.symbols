//// [tests/cases/compiler/tluaLocalPackUnionNarrowingRagged.tlua] ////

=== tluaLocalPackUnionNarrowingRagged.tlua ===
// Arms of DIFFERENT arity. The discriminant below sits at position 2, which
// exists only in the longer arm -- narrowing keys on a number-key property that
// must be present in every constituent, so without padding the shorter arm to the
// union's widest arity this position discriminates nothing.
//
// Note the position matters: discriminating at position 1 (present in both arms)
// would pass whether or not the padding works, and would hide the bug.
declare function ragged(): (number, nil) | (nil, string, boolean)
>ragged : Symbol(ragged, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 0, 0))

local v, e, flag = ragged();
>v : Symbol(v, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 9, 5))
>e : Symbol(e, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 9, 8))
>flag : Symbol(flag, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 9, 11))
>ragged : Symbol(ragged, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 0, 0))

if flag ~= nil then
>flag : Symbol(flag, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 9, 11))

  // Selects the three-element arm.
  local ee: string = e;
>ee : Symbol(ee, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 12, 7))
>e : Symbol(e, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 9, 8))

  local none: nil = v;
>none : Symbol(none, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 13, 7))
>v : Symbol(v, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 9, 5))

end

// The short arm is still reachable, and padding does not invent values: position
// 2 reads as nil there, exactly as Lua returns it.
local v2, e2, flag2 = ragged();
>v2 : Symbol(v2, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 18, 5))
>e2 : Symbol(e2, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 18, 9))
>flag2 : Symbol(flag2, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 18, 13))
>ragged : Symbol(ragged, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 0, 0))

if flag2 == nil then
>flag2 : Symbol(flag2, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 18, 13))

  local n2: number = v2;
>n2 : Symbol(n2, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 20, 7))
>v2 : Symbol(v2, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 18, 5))

  local none2: nil = e2;
>none2 : Symbol(none2, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 21, 7))
>e2 : Symbol(e2, Decl(tluaLocalPackUnionNarrowingRagged.tlua, 18, 9))

end

