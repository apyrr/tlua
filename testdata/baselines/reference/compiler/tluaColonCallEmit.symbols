// A parenthesized receiver keeps its parentheses.
local b = (T):bump();
>b : Symbol(b, Decl(tluaColonCallEmit.tlua, 12, 5))
>(T):bump : Symbol(bump, Decl(tluaColonCallEmit.tlua, 0, 20))
>T : Symbol(T, Decl(tluaColonCallEmit.tlua, 0, 5))
>bump : Symbol(bump, Decl(tluaColonCallEmit.tlua, 0, 20))

// Parentheses around the whole call truncate it to one value.
local c = (T:bump());
>c : Symbol(c, Decl(tluaColonCallEmit.tlua, 15, 5))
>T:bump : Symbol(bump, Decl(tluaColonCallEmit.tlua, 0, 20))
>T : Symbol(T, Decl(tluaColonCallEmit.tlua, 0, 5))
>bump : Symbol(bump, Decl(tluaColonCallEmit.tlua, 0, 20))

// Chains keep every colon.
