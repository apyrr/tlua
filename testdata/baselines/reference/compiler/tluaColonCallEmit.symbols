>u : Symbol(u, Decl(tluaColonCallEmit.tlua, 18, 11))
>bump : Symbol(bump, Decl(tluaColonCallEmit.tlua, 0, 20))

// Return- and throw-position colon calls keep their colon: the no-ASI
