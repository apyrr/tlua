//// [tests/cases/compiler/templateLiteralInferenceSupplementarySplit.tlua] ////

=== templateLiteralInferenceSupplementarySplit.tlua ===
// Template literal type inference consumes one code point at a time, matching
// the string iterator (`[x, ..._] = s`) rather than UTF-16 code-unit indexing
// (`s[0]`). A supplementary code point is therefore kept whole rather than being
// split into its surrogate halves: Head<"😀abc"> is "😀" and Rest<"😀abc"> is
// "abc". This intentionally diverges from tsc, which advances one code unit at a
// time and yields the high surrogate "\uD83D".
type Head<S extends string> = S extends `${infer H}${infer _R}` ? H : never;
>Head : Symbol(Head, Decl(templateLiteralInferenceSupplementarySplit.tlua, 0, 0))
>S : Symbol(S, Decl(templateLiteralInferenceSupplementarySplit.tlua, 6, 10))
>S : Symbol(S, Decl(templateLiteralInferenceSupplementarySplit.tlua, 6, 10))
>H : Symbol(H, Decl(templateLiteralInferenceSupplementarySplit.tlua, 6, 48))
>_R : Symbol(_R, Decl(templateLiteralInferenceSupplementarySplit.tlua, 6, 58))
>H : Symbol(H, Decl(templateLiteralInferenceSupplementarySplit.tlua, 6, 48))

type Rest<S extends string> = S extends `${infer _H}${infer R}` ? R : never;
>Rest : Symbol(Rest, Decl(templateLiteralInferenceSupplementarySplit.tlua, 6, 76))
>S : Symbol(S, Decl(templateLiteralInferenceSupplementarySplit.tlua, 7, 10))
>S : Symbol(S, Decl(templateLiteralInferenceSupplementarySplit.tlua, 7, 10))
>_H : Symbol(_H, Decl(templateLiteralInferenceSupplementarySplit.tlua, 7, 48))
>R : Symbol(R, Decl(templateLiteralInferenceSupplementarySplit.tlua, 7, 59))
>R : Symbol(R, Decl(templateLiteralInferenceSupplementarySplit.tlua, 7, 59))

type H = Head<"\u{1F600}abc">;
>H : Symbol(H, Decl(templateLiteralInferenceSupplementarySplit.tlua, 7, 76))
>Head : Symbol(Head, Decl(templateLiteralInferenceSupplementarySplit.tlua, 0, 0))

type R = Rest<"\u{1F600}abc">;
>R : Symbol(R, Decl(templateLiteralInferenceSupplementarySplit.tlua, 9, 30))
>Rest : Symbol(Rest, Decl(templateLiteralInferenceSupplementarySplit.tlua, 6, 76))

local h: "\u{1F600}" = "x" as unknown as H;
>h : Symbol(h, Decl(templateLiteralInferenceSupplementarySplit.tlua, 12, 5))
>H : Symbol(H, Decl(templateLiteralInferenceSupplementarySplit.tlua, 7, 76))

local r: "abc" = "x" as unknown as R;
>r : Symbol(r, Decl(templateLiteralInferenceSupplementarySplit.tlua, 13, 5))
>R : Symbol(R, Decl(templateLiteralInferenceSupplementarySplit.tlua, 9, 30))

// Reassembling the head and rest reproduces the original string.
type Both = `${H}${R}`;
>Both : Symbol(Both, Decl(templateLiteralInferenceSupplementarySplit.tlua, 13, 37))
>H : Symbol(H, Decl(templateLiteralInferenceSupplementarySplit.tlua, 7, 76))
>R : Symbol(R, Decl(templateLiteralInferenceSupplementarySplit.tlua, 9, 30))

local both: "\u{1F600}abc" = "x" as unknown as Both;
>both : Symbol(both, Decl(templateLiteralInferenceSupplementarySplit.tlua, 17, 5))
>Both : Symbol(Both, Decl(templateLiteralInferenceSupplementarySplit.tlua, 13, 37))

