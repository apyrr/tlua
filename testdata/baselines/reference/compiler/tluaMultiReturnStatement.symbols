// Inference: the return list infers a pack without an annotation.
function inferredPair()
>inferredPair : Symbol(inferredPair, Decl(tluaMultiReturnStatement.tlua, 2, 3))

  return 1, "a";
end

// Inference across mixed arities pads with nil.
function mixed(cond: boolean) {
>mixed : Symbol(mixed, Decl(tluaMultiReturnStatement.tlua, 7, 3))
>cond : Symbol(cond, Decl(tluaMultiReturnStatement.tlua, 10, 15))

  if (cond) {
>cond : Symbol(cond, Decl(tluaMultiReturnStatement.tlua, 10, 15))

    return 1, "a";
  }
  return 2;
}

// A bare return contributes zero values.
function maybeNothing(cond: boolean) {
>maybeNothing : Symbol(maybeNothing, Decl(tluaMultiReturnStatement.tlua, 15, 1))
>cond : Symbol(cond, Decl(tluaMultiReturnStatement.tlua, 18, 22))

  if (cond) {
>cond : Symbol(cond, Decl(tluaMultiReturnStatement.tlua, 18, 22))

    return;
  }
  return 1, "a";
}

// `return f()` forwards the whole pack.
function forward(): (number, string)
>forward : Symbol(forward, Decl(tluaMultiReturnStatement.tlua, 23, 1))

