//// [tests/cases/compiler/tluaAsyncContract.tlua] ////

=== tluaAsyncContract.tlua ===
// The tlua coroutine contract: an async function may only be called from an
// async context. Async functions return their plain type (or pack), never
// Promise<T>.

declare function request(url: string): (boolean, any);
>request : (url: string) => (boolean, any)
>url : string

declare namespace coroutine {
>declare : any
>namespace : any
>coroutine : CoroutineLib

  function create(f: (...: any) => any): any;
>create : (f: (...: any) => any) => any
>f : (...: any) => any
> : any[]

  function wrap(f: (...: any) => any): (...: any) => any;
>wrap : (f: (...: any) => any) => (...: any) => any
>f : (...: any) => any
> : any[]
> : any[]
}

async function fetchOk(url: string): (boolean, any)
>fetchOk : async (url: string) => (boolean, any)
>url : string

  local ok, res = request(url);
>ok : boolean
>res : any
>request(url) : boolean
>request : (url: string) => (boolean, any)
>url : string

  return ok, res;
>ok, res : boolean, any
>ok : boolean
>res : any

end

// OK: direct call from an async context; the result is the plain pack.
async function handler(): number
>handler : async () => number

  local ok, res = fetchOk("https://example.com");
>ok : boolean
>res : any
>fetchOk("https://example.com") : boolean
>fetchOk : async (url: string) => (boolean, any)
>"https://example.com" : "https://example.com"

  if ok then
>ok : boolean

    return 1;
>1 : 1

  end
  return 0;
>0 : 0

end

// Error: direct call from a sync function.
function syncCaller(): void
>syncCaller : () => void

  fetchOk("nope");
>fetchOk("nope") : boolean
>fetchOk : async (url: string) => (boolean, any)
>"nope" : "nope"

end

// Error: call at top level.
fetchOk("top");
>fetchOk("top") : boolean
>fetchOk : async (url: string) => (boolean, any)
>"top" : "top"

// Error: inferred alias keeps the contract (the flag rides the signature).
function aliasCaller(): void
>aliasCaller : () => void

  local f = fetchOk;
>f : async (url: string) => (boolean, any)
>fetchOk : async (url: string) => (boolean, any)

  f("aliased");
>f("aliased") : boolean
>f : async (url: string) => (boolean, any)
>"aliased" : "aliased"

end

// OK: alias called from an async context.
async function aliasAsyncCaller(): void
>aliasAsyncCaller : async () => void

  local f = fetchOk;
>f : async (url: string) => (boolean, any)
>fetchOk : async (url: string) => (boolean, any)

  f("aliased");
>f("aliased") : boolean
>f : async (url: string) => (boolean, any)
>"aliased" : "aliased"

end

// OK: passing an async function as a value is not a call.
coroutine.create(fetchOk);
>coroutine.create(fetchOk) : thread
>coroutine.create : (fn: function) => thread
>coroutine : CoroutineLib
>create : (fn: function) => thread
>fetchOk : async (url: string) => (boolean, any)

local wrapped = coroutine.wrap(fetchOk);
>wrapped : function
>coroutine.wrap(fetchOk) : function
>coroutine.wrap : (fn: function) => function
>coroutine : CoroutineLib
>wrap : (fn: function) => function
>fetchOk : async (url: string) => (boolean, any)

// OK: async recursion.
async function pingpong(n: number): number
>pingpong : async (n: number) => number
>n : number

  if n <= 0 then
>n <= 0 : boolean
>n : number
>0 : 0

    return 0;
>0 : 0

  end
  return pingpong(n - 1);
>pingpong(n - 1) : number
>pingpong : async (n: number) => number
>n - 1 : number
>n : number
>1 : 1

end

// Async arrow expressions participate too.
local asyncArrow = async function(): number return 42 end;
>asyncArrow : async () => number
>async function(): number return 42 end : async () => number
>42 : 42

function arrowSyncCaller(): void
>arrowSyncCaller : () => void

  asyncArrow(); // error
>asyncArrow() : number
>asyncArrow : async () => number

end
async function arrowAsyncCaller(): number
>arrowAsyncCaller : async () => number

  return asyncArrow(); // OK
>asyncArrow() : number
>asyncArrow : async () => number

end

// Generic async functions keep the flag through instantiation.
async function identityAsync<T>(x: T): T
>identityAsync : async <T>(x: T) => T
>x : T

  return x;
>x : T

end
function genericSyncCaller(): void
>genericSyncCaller : () => void

  identityAsync(1); // error
>identityAsync(1) : 1
>identityAsync : async <T>(x: T) => T
>1 : 1

end
async function genericAsyncCaller(): number
>genericAsyncCaller : async () => number

  return identityAsync(2); // OK
>identityAsync(2) : 2
>identityAsync : async <T>(x: T) => T
>2 : 2

end

// The async return type is the plain type, not Promise<T>.
async function plain(): number
>plain : async () => number

  return 3;
>3 : 3

end
async function usePlain(): number
>usePlain : async () => number

  local n = plain();
>n : number
>plain() : number
>plain : async () => number

  return n + 1;
>n + 1 : number
>n : number
>1 : 1

end

