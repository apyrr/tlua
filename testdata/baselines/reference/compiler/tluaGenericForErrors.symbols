// Value 1 must be callable — reported once.
function notCallable(): void
>notCallable : Symbol(notCallable, Decl(tluaGenericForErrors.tlua, 0, 0))

  for k in 42 do
>k : Symbol(k, Decl(tluaGenericForErrors.tlua, 2, 5))

    k;
>k : Symbol(k, Decl(tluaGenericForErrors.tlua, 2, 5))

  end
end

// An `any` iterator types the names as any, silently.
declare anything: any;
>anything : Symbol(anything, Decl(tluaGenericForErrors.tlua, 8, 7))

function anyIterator(): void
>anyIterator : Symbol(anyIterator, Decl(tluaGenericForErrors.tlua, 8, 22))

  for k, v in anything do
>k : Symbol(k, Decl(tluaGenericForErrors.tlua, 11, 5))
>v : Symbol(v, Decl(tluaGenericForErrors.tlua, 11, 8))
>anything : Symbol(anything, Decl(tluaGenericForErrors.tlua, 8, 7))

    k;
>k : Symbol(k, Decl(tluaGenericForErrors.tlua, 11, 5))

    v;
>v : Symbol(v, Decl(tluaGenericForErrors.tlua, 11, 8))

  end
end

