>mt : Symbol(mt, Decl(tluaMetatableStatement.tlua, 88, 20))
>mt : Symbol(mt, Decl(tluaMetatableStatement.tlua, 6, 5))

  while cond do
>cond : Symbol(cond, Decl(tluaMetatableStatement.tlua, 87, 25))

    setmetatable(t, t.mt);
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
