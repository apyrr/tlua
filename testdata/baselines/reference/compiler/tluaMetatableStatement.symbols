>t.mt : Symbol(mt, Decl(tluaMetatableStatement.tlua, 88, 20))
>t : Symbol(t, Decl(tluaMetatableStatement.tlua, 88, 7))
>mt : Symbol(mt, Decl(tluaMetatableStatement.tlua, 88, 20))

  end
