=== main.tlua ===
// A resolved project file wins over the ambient require() overloads: this is
// the project module, not the lualib JITProfileLib.
local profile = require("jit.profile");
>profile : { marker: string; }
>require("jit.profile") : { marker: string; }
>require : { (module: "bit"): BitLib; (module: "jit"): JITLib; (module: "ffi"): FFILib; (module: "jit.profile"): JITProfileLib; (module: "jit.util"): JITUtilLib; (module: "table.clear"): TableClear; (module: "table.new"): TableNew; (module: "string.buffer"): StringBufferLib; (module: string): any; }
>"jit.profile" : "jit.profile"

local s: string = profile.marker;
>s : string
>profile.marker : string
>profile : { marker: string; }
>marker : string

// The unshadowed lualib names still hit their overloads.
local util = require("jit.util");
>util : JITUtilLib
>require("jit.util") : JITUtilLib
>require : { (module: "bit"): BitLib; (module: "jit"): JITLib; (module: "ffi"): FFILib; (module: "jit.profile"): JITProfileLib; (module: "jit.util"): JITUtilLib; (module: "table.clear"): TableClear; (module: "table.new"): TableNew; (module: "string.buffer"): StringBufferLib; (module: string): any; }
>"jit.util" : "jit.util"

util.funcinfo;
>util.funcinfo : (fn: LuaFunction, pc?: number) => JITFunctionInfo
>util : JITUtilLib
>funcinfo : (fn: LuaFunction, pc?: number) => JITFunctionInfo

=== jit/profile.tlua ===
// A project file that shadows a lualib module name.
local marker = "project";
>marker : string
>"project" : "project"

return { marker = marker };
