>length : Symbol(length, Decl(tluaSelfType.tlua, 9, 16))
>message : Symbol(message, Decl(tluaSelfType.tlua, 9, 32))

	trim(length: number): self;
>trim : Symbol(HexZodStringSchema.trim, Decl(tluaSelfType.tlua, 9, 57))
