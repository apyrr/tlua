>self : Symbol(self, Decl(tluaSelfType.tlua, 8, 5))
>length : Symbol(length, Decl(tluaSelfType.tlua, 8, 16))
>message : Symbol(message, Decl(tluaSelfType.tlua, 8, 32))

	max(self: self, length: number, message?: string): self;
>max : Symbol(HexZodStringSchema.max, Decl(tluaSelfType.tlua, 8, 57))
