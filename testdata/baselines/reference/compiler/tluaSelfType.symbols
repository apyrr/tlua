=== tluaSelfType.tlua ===
// `self` is a receiver-relative type inside an interface. Inherited members
// substitute the most-derived interface, which keeps fluent chains precise.

interface HexZodSchema<T> {
>HexZodSchema : Symbol(HexZodSchema, Decl(tluaSelfType.tlua, 0, 0))
>T : Symbol(T, Decl(tluaSelfType.tlua, 3, 23))

	parse(self: self, value: unknown): T;
>parse : Symbol(HexZodSchema.parse, Decl(tluaSelfType.tlua, 3, 27))
>self : Symbol(self, Decl(tluaSelfType.tlua, 4, 7))
>value : Symbol(value, Decl(tluaSelfType.tlua, 4, 18))
>T : Symbol(T, Decl(tluaSelfType.tlua, 3, 23))
}

interface HexZodStringSchema extends HexZodSchema<string> {
