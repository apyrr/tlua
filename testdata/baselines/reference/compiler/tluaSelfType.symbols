	copy(): self;
>copy : Symbol(HexZodStringSchema.copy, Decl(tluaSelfType.tlua, 10, 28))

	peer: self;
>peer : Symbol(HexZodStringSchema.peer, Decl(tluaSelfType.tlua, 11, 14))
}

interface BrandedStringSchema extends HexZodStringSchema {
>BrandedStringSchema : Symbol(BrandedStringSchema, Decl(tluaSelfType.tlua, 13, 1))
