=== tluaMetatableChained.tlua ===
// A metatable's __index may be a table that has a metatable of its own, and Lua keeps
// walking. Nothing special is needed for that: each pairing already carries the members it
// inherited, so a chain merges one link at a time.

local base = { fromBase = true };
>base : Symbol(base, Decl(tluaMetatableChained.tlua, 4, 5))
>fromBase : Symbol(fromBase, Decl(tluaMetatableChained.tlua, 4, 14))

local mid = setmetatable({ fromMid = 1 }, { __index = base });
>mid : Symbol(mid, Decl(tluaMetatableChained.tlua, 5, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>fromMid : Symbol(fromMid, Decl(tluaMetatableChained.tlua, 5, 26))
>__index : Symbol(__index, Decl(tluaMetatableChained.tlua, 5, 43))
>base : Symbol(base, Decl(tluaMetatableChained.tlua, 4, 5))

local top = setmetatable({ fromTop = "t" }, { __index = mid });
>top : Symbol(top, Decl(tluaMetatableChained.tlua, 6, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
