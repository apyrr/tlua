//// [tests/cases/compiler/tluaAndOrNot.tlua] ////

=== tluaAndOrNot.tlua ===
// `and`, `or` and `not` are Lua's spellings of `&&`, `||` and `!`. They are
// aliases -- the same token kinds -- so the two spellings parse, check and emit
// identically, and the words are canonical on the way out. `not` is the one
// exception: its token kind is shared with the non-null and definite-assignment
// `!`, which must stay punctuation, so `not x` emits as `!x`.

declare s: string;
>s : string

declare n: number;
>n : number

declare b: boolean;
>b : boolean

declare maybe: string | nil;
>maybe : string | nil

// Both spellings, same meaning.
local w1 = s and n;
>w1 : number
>s and n : number
>s : string
>n : number

local p1 = s && n;
>p1 : number
>s && n : number
>s : string
>n : number

local w2 = s or n;
>w2 : string
>s or n : string
>s : string
>n : number

local p2 = s || n;
>p2 : string
>s || n : string
>s : string
>n : number

local w3 = not b;
>w3 : boolean
>not b : boolean
>b : boolean

local p3 = !b;
>p3 : boolean
>!b : boolean
>b : boolean

// Mixed within one expression.
local m1 = (s and n) || (n and s);
>m1 : number
>(s and n) || (n and s) : number
>(s and n) : number
>s and n : number
>s : string
>n : number
>(n and s) : string
>n and s : string
>n : number
>s : string

local m2 = not b && b;
>m2 : false
>not b && b : false
>not b : boolean
>b : boolean
>b : false

// Precedence agrees between the languages: comparison binds tighter than `and`,
// which binds tighter than `or`. All four spell the same tree.
local prec1 = n > 1 and n < 5 or b;
>prec1 : boolean
>n > 1 and n < 5 or b : boolean
>n > 1 and n < 5 : boolean
>n > 1 : boolean
>n : number
>1 : 1
>n < 5 : boolean
>n : number
>5 : 5
>b : boolean

local prec2 = n > 1 && n < 5 || b;
>prec2 : boolean
>n > 1 && n < 5 || b : boolean
>n > 1 && n < 5 : boolean
>n > 1 : boolean
>n : number
>1 : 1
>n < 5 : boolean
>n : number
>5 : 5
>b : boolean

local prec3 = (n > 1 and n < 5) or b;
>prec3 : boolean
>(n > 1 and n < 5) or b : boolean
>(n > 1 and n < 5) : boolean
>n > 1 and n < 5 : boolean
>n > 1 : boolean
>n : number
>1 : 1
>n < 5 : boolean
>n : number
>5 : 5
>b : boolean

local prec4 = ((n > 1) && (n < 5)) || b;
>prec4 : boolean
>((n > 1) && (n < 5)) || b : boolean
>((n > 1) && (n < 5)) : boolean
>(n > 1) && (n < 5) : boolean
>(n > 1) : boolean
>n > 1 : boolean
>n : number
>1 : 1
>(n < 5) : boolean
>n < 5 : boolean
>n : number
>5 : 5
>b : boolean

// `not` does not disturb the other uses of `!`.
local nonNull = maybe!.length;
>nonNull : number
>maybe!.length : number
>maybe! : string
>maybe : string | nil
>length : number

local doubleNot = not not maybe;
>doubleNot : boolean
>not not maybe : boolean
>not maybe : boolean
>maybe : string | nil

// Optional chaining lowers to an `and`-guard.
local chain = maybe?.length;
>chain : number | nil
>maybe?.length : number | nil
>maybe : string | nil
>length : number | nil

// The words are reserved, so a table key must be quoted, as in Lua.
declare t: { [k: string]: number };
>t : { [k: string]: number; }
>k : string

local byIndex = t["and"];
>byIndex : number
>t["and"] : number
>t : { [k: string]: number; }
>"and" : "and"

local byIndex2 = t["or"];
>byIndex2 : number
>t["or"] : number
>t : { [k: string]: number; }
>"or" : "or"

local byIndex3 = t["not"];
>byIndex3 : number
>t["not"] : number
>t : { [k: string]: number; }
>"not" : "not"

