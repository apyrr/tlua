>h : Symbol(h, Decl(tluaWhileStatement.tlua, 31, 24))

      count = count + 1;
>count : Symbol(count, Decl(tluaWhileStatement.tlua, 32, 7))
>count : Symbol(count, Decl(tluaWhileStatement.tlua, 32, 7))

      y = y + 1;
>y : Symbol(y, Decl(tluaWhileStatement.tlua, 35, 9))
>y : Symbol(y, Decl(tluaWhileStatement.tlua, 35, 9))

    end
