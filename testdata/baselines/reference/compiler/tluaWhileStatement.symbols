// Parenthesized condition with `do` is Lua.
function parens(flag: boolean): number
>parens : Symbol(parens, Decl(tluaWhileStatement.tlua, 8, 3))
>flag : Symbol(flag, Decl(tluaWhileStatement.tlua, 11, 16))

  local n = 0;
>n : Symbol(n, Decl(tluaWhileStatement.tlua, 12, 7))

  while (flag) do
>flag : Symbol(flag, Decl(tluaWhileStatement.tlua, 11, 16))

    flag = false;
>flag : Symbol(flag, Decl(tluaWhileStatement.tlua, 11, 16))

    n = 1;
>n : Symbol(n, Decl(tluaWhileStatement.tlua, 12, 7))

  end
  return n;
>n : Symbol(n, Decl(tluaWhileStatement.tlua, 12, 7))

end

// break exits the loop; one-liner bodies parse (ASI before `end`).
function firstOver(limit: number): number
>firstOver : Symbol(firstOver, Decl(tluaWhileStatement.tlua, 18, 3))
>limit : Symbol(limit, Decl(tluaWhileStatement.tlua, 21, 19))

  local i = 0;
>i : Symbol(i, Decl(tluaWhileStatement.tlua, 22, 7))

  while true do
    if i > limit then break end
>i : Symbol(i, Decl(tluaWhileStatement.tlua, 22, 7))
>limit : Symbol(limit, Decl(tluaWhileStatement.tlua, 21, 19))

    i = i + 1;
>i : Symbol(i, Decl(tluaWhileStatement.tlua, 22, 7))
>i : Symbol(i, Decl(tluaWhileStatement.tlua, 22, 7))

  end
  return i;
>i : Symbol(i, Decl(tluaWhileStatement.tlua, 22, 7))

end

// Nested while loops.
