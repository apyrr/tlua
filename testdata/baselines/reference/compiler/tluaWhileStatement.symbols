>x : Symbol(x, Decl(tluaWhileStatement.tlua, 33, 7))
>x : Symbol(x, Decl(tluaWhileStatement.tlua, 33, 7))

  end
  return count;
>count : Symbol(count, Decl(tluaWhileStatement.tlua, 32, 7))

end

