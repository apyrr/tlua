=== tluaIterationCoexistence.tlua ===
// TS iteration (`for..of`, array-literal spread, array destructuring) is
// removed. Lua iteration remains: the generic-for drives an iterator function,
// and a number-key table spreads and is indexed like a sequence.

declare function iterStep(t: string[], i: number): (number, string?);
>iterStep : Symbol(iterStep, Decl(tluaIterationCoexistence.tlua, 0, 0))
>t : Symbol(t, Decl(tluaIterationCoexistence.tlua, 4, 26))
>i : Symbol(i, Decl(tluaIterationCoexistence.tlua, 4, 38))

declare function ipairsLike(t: string[]): typeof iterStep;
>ipairsLike : Symbol(ipairsLike, Decl(tluaIterationCoexistence.tlua, 4, 69))
>t : Symbol(t, Decl(tluaIterationCoexistence.tlua, 5, 28))
>iterStep : Symbol(iterStep, Decl(tluaIterationCoexistence.tlua, 0, 0))

// Lua generic-for over an iterator function; the names take their positions
// from the step function's return pack.
function walk(t: string[]): number
>walk : Symbol(walk, Decl(tluaIterationCoexistence.tlua, 5, 58))
>t : Symbol(t, Decl(tluaIterationCoexistence.tlua, 9, 14))

  local count = 0;
>count : Symbol(count, Decl(tluaIterationCoexistence.tlua, 10, 7))

  for i, s in ipairsLike(t) do
>i : Symbol(i, Decl(tluaIterationCoexistence.tlua, 11, 5))
>s : Symbol(s, Decl(tluaIterationCoexistence.tlua, 11, 8))
>ipairsLike : Symbol(ipairsLike, Decl(tluaIterationCoexistence.tlua, 4, 69))
>t : Symbol(t, Decl(tluaIterationCoexistence.tlua, 9, 14))

    count = count + i;
>count : Symbol(count, Decl(tluaIterationCoexistence.tlua, 10, 7))
>count : Symbol(count, Decl(tluaIterationCoexistence.tlua, 10, 7))
>i : Symbol(i, Decl(tluaIterationCoexistence.tlua, 11, 5))

  end
  return count;
>count : Symbol(count, Decl(tluaIterationCoexistence.tlua, 10, 7))

end

// A number-key table satisfies T[] and is indexed element-wise.
function sum(xs: number[]): number
>sum : Symbol(sum, Decl(tluaIterationCoexistence.tlua, 15, 3))
>xs : Symbol(xs, Decl(tluaIterationCoexistence.tlua, 18, 13))

  local total = 0;
>total : Symbol(total, Decl(tluaIterationCoexistence.tlua, 19, 7))

  for i = 1, 3 do
>i : Symbol(i, Decl(tluaIterationCoexistence.tlua, 20, 5))

    total = total + xs[i];
>total : Symbol(total, Decl(tluaIterationCoexistence.tlua, 19, 7))
>total : Symbol(total, Decl(tluaIterationCoexistence.tlua, 19, 7))
>xs : Symbol(xs, Decl(tluaIterationCoexistence.tlua, 18, 13))
>i : Symbol(i, Decl(tluaIterationCoexistence.tlua, 20, 5))

  end
  return total;
>total : Symbol(total, Decl(tluaIterationCoexistence.tlua, 19, 7))

end

// A vararg pack collects into a number-key table with `{...}`.
function join(sep: string, ...: string): string
>join : Symbol(join, Decl(tluaIterationCoexistence.tlua, 24, 3))
>sep : Symbol(sep, Decl(tluaIterationCoexistence.tlua, 27, 14))
> : Symbol((Missing), Decl(tluaIterationCoexistence.tlua, 27, 26))

  local parts: string[] = {...};
>parts : Symbol(parts, Decl(tluaIterationCoexistence.tlua, 28, 7))

  return parts[1];
>parts : Symbol(parts, Decl(tluaIterationCoexistence.tlua, 28, 7))

end
