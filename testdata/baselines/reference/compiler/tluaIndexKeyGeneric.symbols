//// [tests/cases/compiler/tluaIndexKeyGeneric.tlua] ////

=== tluaIndexKeyGeneric.tlua ===
// A Lua table is keyed by any non-nil value, so an index signature may be keyed by a
// type parameter. This is what makes `Table<K, V>` -- and every standard library
// signature built on it -- mean anything.

interface Map2<K, V> {
>Map2 : Symbol(Map2, Decl(tluaIndexKeyGeneric.tlua, 0, 0))
>K : Symbol(K, Decl(tluaIndexKeyGeneric.tlua, 4, 15))
>V : Symbol(V, Decl(tluaIndexKeyGeneric.tlua, 4, 17))

  [key: K]: V;
>key : Symbol(key, Decl(tluaIndexKeyGeneric.tlua, 5, 3))
>K : Symbol(K, Decl(tluaIndexKeyGeneric.tlua, 4, 15))
>V : Symbol(V, Decl(tluaIndexKeyGeneric.tlua, 4, 17))
}

// The key instantiates along with the value.
declare byName: Map2<string, number>;
>byName : Symbol(byName, Decl(tluaIndexKeyGeneric.tlua, 9, 7))
>Map2 : Symbol(Map2, Decl(tluaIndexKeyGeneric.tlua, 0, 0))

local n: number = byName["a"];
>n : Symbol(n, Decl(tluaIndexKeyGeneric.tlua, 10, 5))
>byName : Symbol(byName, Decl(tluaIndexKeyGeneric.tlua, 9, 7))

declare byPoint: Map2<{ x: number }, string>;
>byPoint : Symbol(byPoint, Decl(tluaIndexKeyGeneric.tlua, 12, 7))
>Map2 : Symbol(Map2, Decl(tluaIndexKeyGeneric.tlua, 0, 0))
>x : Symbol(x, Decl(tluaIndexKeyGeneric.tlua, 12, 23))

declare pt: { x: number };
>pt : Symbol(pt, Decl(tluaIndexKeyGeneric.tlua, 13, 7))
>x : Symbol(x, Decl(tluaIndexKeyGeneric.tlua, 13, 13))

local s: string = byPoint[pt];
>s : Symbol(s, Decl(tluaIndexKeyGeneric.tlua, 14, 5))
>byPoint : Symbol(byPoint, Decl(tluaIndexKeyGeneric.tlua, 12, 7))
>pt : Symbol(pt, Decl(tluaIndexKeyGeneric.tlua, 13, 7))

// keyof yields the key itself, not string | number | symbol.
type K1 = keyof Map2<string, number>;
>K1 : Symbol(K1, Decl(tluaIndexKeyGeneric.tlua, 14, 30))
>Map2 : Symbol(Map2, Decl(tluaIndexKeyGeneric.tlua, 0, 0))

local k1: K1 = "a";
>k1 : Symbol(k1, Decl(tluaIndexKeyGeneric.tlua, 18, 5))
>K1 : Symbol(K1, Decl(tluaIndexKeyGeneric.tlua, 14, 30))

type K2 = keyof Map2<boolean, number>;
>K2 : Symbol(K2, Decl(tluaIndexKeyGeneric.tlua, 18, 19))
>Map2 : Symbol(Map2, Decl(tluaIndexKeyGeneric.tlua, 0, 0))

local k2: K2 = true;
>k2 : Symbol(k2, Decl(tluaIndexKeyGeneric.tlua, 20, 5))
>K2 : Symbol(K2, Decl(tluaIndexKeyGeneric.tlua, 18, 19))

// The index resolves inside a generic body: `Table<K, V>[K]` is `V`, never a deferred
// indexed access nothing can simplify.
function get<K, V>(t: Table<K, V>, k: K): V
>get : Symbol(get, Decl(tluaIndexKeyGeneric.tlua, 20, 20))
>K : Symbol(K, Decl(tluaIndexKeyGeneric.tlua, 24, 13))
>V : Symbol(V, Decl(tluaIndexKeyGeneric.tlua, 24, 15))
>t : Symbol(t, Decl(tluaIndexKeyGeneric.tlua, 24, 19))
>Table : Symbol(Table, Decl(lib.luajit.d.tlua, --, --))
>K : Symbol(K, Decl(tluaIndexKeyGeneric.tlua, 24, 13))
>V : Symbol(V, Decl(tluaIndexKeyGeneric.tlua, 24, 15))
>k : Symbol(k, Decl(tluaIndexKeyGeneric.tlua, 24, 34))
>K : Symbol(K, Decl(tluaIndexKeyGeneric.tlua, 24, 13))
>V : Symbol(V, Decl(tluaIndexKeyGeneric.tlua, 24, 15))

  return t[k];
>t : Symbol(t, Decl(tluaIndexKeyGeneric.tlua, 24, 19))
>k : Symbol(k, Decl(tluaIndexKeyGeneric.tlua, 24, 34))

end

