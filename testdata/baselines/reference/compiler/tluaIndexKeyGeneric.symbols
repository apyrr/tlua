// A union key instantiates to two disjoint indexes, not one union-keyed index.
declare both: Map2<string | number, boolean>;
>both : Symbol(both, Decl(tluaIndexKeyGeneric.tlua, 47, 7))
>Map2 : Symbol(Map2, Decl(tluaIndexKeyGeneric.tlua, 0, 0))

local b1: boolean = both["a"];
>b1 : Symbol(b1, Decl(tluaIndexKeyGeneric.tlua, 48, 5))
>both : Symbol(both, Decl(tluaIndexKeyGeneric.tlua, 47, 7))

local b2: boolean = both[1];
>b2 : Symbol(b2, Decl(tluaIndexKeyGeneric.tlua, 49, 5))
>both : Symbol(both, Decl(tluaIndexKeyGeneric.tlua, 47, 7))

// The whole point: the standard library comes alive. The key keeps its literal names --
// `"a" | "b"`, exactly what `keyof m` reports -- rather than widening to string.
local m = { a = 1, b = 2 };
>m : Symbol(m, Decl(tluaIndexKeyGeneric.tlua, 53, 5))
>a : Symbol(a, Decl(tluaIndexKeyGeneric.tlua, 53, 11))
>b : Symbol(b, Decl(tluaIndexKeyGeneric.tlua, 53, 18))

for k, v in pairs(m) do
>k : Symbol(k, Decl(tluaIndexKeyGeneric.tlua, 54, 3))
>v : Symbol(v, Decl(tluaIndexKeyGeneric.tlua, 54, 6))
>pairs : Symbol(pairs, Decl(lib.luajit.d.tlua, --, --))
>m : Symbol(m, Decl(tluaIndexKeyGeneric.tlua, 53, 5))

  local key: "a" | "b" = k;
>key : Symbol(key, Decl(tluaIndexKeyGeneric.tlua, 55, 7))
>k : Symbol(k, Decl(tluaIndexKeyGeneric.tlua, 54, 3))

  local alsoAString: string = k;
>alsoAString : Symbol(alsoAString, Decl(tluaIndexKeyGeneric.tlua, 56, 7))
>k : Symbol(k, Decl(tluaIndexKeyGeneric.tlua, 54, 3))

  local value: number = v;
>value : Symbol(value, Decl(tluaIndexKeyGeneric.tlua, 57, 7))
>v : Symbol(v, Decl(tluaIndexKeyGeneric.tlua, 54, 6))

end

local got: number | nil = rawget(m, "a");
>got : Symbol(got, Decl(tluaIndexKeyGeneric.tlua, 60, 5))
>rawget : Symbol(rawget, Decl(lib.luajit.d.tlua, --, --))
>m : Symbol(m, Decl(tluaIndexKeyGeneric.tlua, 53, 5))

// A supplied key wins over the table's own keys (it is inferred at the priority a
// mapped type constraint uses), so adding a key a table does not have yet -- rawset is
// how a key is added, in any domain -- always type-checks: a Lua table is open.
rawset(m, "c", 3);
>rawset : Symbol(rawset, Decl(lib.luajit.d.tlua, --, --))
>m : Symbol(m, Decl(tluaIndexKeyGeneric.tlua, 53, 5))

rawset(m, 5, 3);
>rawset : Symbol(rawset, Decl(lib.luajit.d.tlua, --, --))
>m : Symbol(m, Decl(tluaIndexKeyGeneric.tlua, 53, 5))

// A recursive table type, spelled by name.
type RecTable = Table<string, RecTable | number>;
>RecTable : Symbol(RecTable, Decl(tluaIndexKeyGeneric.tlua, 66, 16))
>Table : Symbol(Table, Decl(lib.luajit.d.tlua, --, --))
>RecTable : Symbol(RecTable, Decl(tluaIndexKeyGeneric.tlua, 66, 16))

declare rt: RecTable;
>rt : Symbol(rt, Decl(tluaIndexKeyGeneric.tlua, 70, 7))
>RecTable : Symbol(RecTable, Decl(tluaIndexKeyGeneric.tlua, 66, 16))

local rec = rt["x"];
>rec : Symbol(rec, Decl(tluaIndexKeyGeneric.tlua, 71, 5))
>rt : Symbol(rt, Decl(tluaIndexKeyGeneric.tlua, 70, 7))

// A number-keyed table iterates with ipairs.
local arr = { 10, 20, 30 };
>arr : Symbol(arr, Decl(tluaIndexKeyGeneric.tlua, 74, 5))

for i, v in ipairs(arr) do
>i : Symbol(i, Decl(tluaIndexKeyGeneric.tlua, 75, 3))
>v : Symbol(v, Decl(tluaIndexKeyGeneric.tlua, 75, 6))
>ipairs : Symbol(ipairs, Decl(lib.luajit.d.tlua, --, --))
>arr : Symbol(arr, Decl(tluaIndexKeyGeneric.tlua, 74, 5))

  local index: number = i;
>index : Symbol(index, Decl(tluaIndexKeyGeneric.tlua, 76, 7))
>i : Symbol(i, Decl(tluaIndexKeyGeneric.tlua, 75, 3))

  local element: number = v;
>element : Symbol(element, Decl(tluaIndexKeyGeneric.tlua, 77, 7))
>v : Symbol(v, Decl(tluaIndexKeyGeneric.tlua, 75, 6))

end

