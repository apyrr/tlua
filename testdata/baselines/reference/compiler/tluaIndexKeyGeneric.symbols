>k : Symbol(k, Decl(tluaIndexKeyGeneric.tlua, 42, 49))
>K : Symbol(K, Decl(tluaIndexKeyGeneric.tlua, 42, 19))
>V : Symbol(V, Decl(tluaIndexKeyGeneric.tlua, 42, 21))

  return t[k];
>t : Symbol(t, Decl(tluaIndexKeyGeneric.tlua, 42, 25))
>k : Symbol(k, Decl(tluaIndexKeyGeneric.tlua, 42, 49))

