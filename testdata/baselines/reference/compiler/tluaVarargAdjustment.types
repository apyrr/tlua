>returnTruncated : (...: string) => (string | nil, string)
> : string[]

  return ..., "last";
>..., "last" : string | nil, string
>... : string | nil
>"last" : "last"

end

// An unbounded tail cannot fill a required fixed return value either.
function returnUnderfilled(...: string): (string, string)
>returnUnderfilled : (...: string) => (string, string)
> : string[]

  return ...;
>... : string | nil

end

function localValueLists(...: number): void
>localValueLists : (...: number) => void
> : number[]

  // Tail expansion: both names come out of the pack.
  local a, b = ...;
>a : number | nil
>b : number | nil
>... : number | nil

  // A non-tail `...` contributes one value; the tail still expands.
  local c, d = ..., 1;
>c : number | nil
>d : number
>..., 1 : number | nil, number
>... : number | nil
>1 : 1

  // Fixed value first, tail expands into the rest.
  local e, f = 1, ...;
>e : number
>f : number | nil
>1, ... : number, ...number
>1 : 1
>... : number | nil

end

function tableConstructors(...: number): void
>tableConstructors : (...: number) => void
> : number[]

  // The last positional entry expands, so the tail lands in the number index.
  local expanded = {1, ...};
>expanded : { [x: number]: number; 1: number; }
>{1, ...} : { [x: number]: number; 1: number; }
>... : number | nil

  // A non-tail `...` stores only its first value.
  local truncated = {..., 1};
>truncated : { 1: number | nil; 2: number; }
>{..., 1} : { 1: number | nil; 2: number; }
>... : number | nil

  // A void pack in tail position contributes zero values, so this table is
  // empty -- it is not `{ 1: void }`.
  local voided = {nothing()};
>voided : {}
>{nothing()} : {}
>nothing() : void
>nothing : () => void

  // Calls expand in the tail exactly like varargs.
  local fromCall = {1, pair()};
>fromCall : { 1: number; 2: number; 3: string; }
>{1, pair()} : { 1: number; 2: number; 3: string; }
>pair() : number
>pair : () => (number, string)

end

function tableTailShapes(...: number): void
>tableTailShapes : (...: number) => void
> : number[]

  // A fixed element *after* an unbounded one has no static index -- it sits
  // wherever the rest ends -- so it joins the number index type instead of
  // claiming index 2.
  local mid = {midRest()};
>mid : { [x: number]: string | number | boolean; 1: number; }
>{midRest()} : { [x: number]: string | number | boolean; 1: number; }
>midRest() : number
>midRest : () => (number, ...string, boolean)

  local notBoolean: boolean = mid[2];
>notBoolean : boolean
>mid[2] : string | number | boolean
>mid : { [x: number]: string | number | boolean; 1: number; }
>2 : 2

  // An optional pack element may be absent, so the property it produces is
  // optional and its type carries nil.
  local opt = {optionalTail()};
>opt : { 1: number; 2?: string | nil; }
>{optionalTail()} : { 1: number; 2?: string | nil; }
>optionalTail() : number
>optionalTail : () => (number, string?)

  local maybeMissing: string = opt[2];
>maybeMissing : string
>opt[2] : string | nil
>opt : { 1: number; 2?: string | nil; }
>2 : 2

  // A computed number key and a pack tail share the number index domain: one
  // signature covers both, so neither hides the other.
  local mixed = { [key] = "s", ... };
>mixed : { [x: number]: string | number; }
>{ [key] = "s", ... } : { [x: number]: string | number; }
>[key] : string
>key : number
>"s" : "s"
>... : number | nil

  local both: string | number = mixed[1];
>both : string | number
>mixed[1] : string | number
>mixed : { [x: number]: string | number; }
>1 : 1

  local notJustNumber: number = mixed[1];
>notJustNumber : number
>mixed[1] : string | number
>mixed : { [x: number]: string | number; }
>1 : 1

