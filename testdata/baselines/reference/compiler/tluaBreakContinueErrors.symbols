// break outside any loop is a grammar error.
function breakOutside(): void
>breakOutside : Symbol(breakOutside, Decl(tluaBreakContinueErrors.tlua, 0, 0))

  break;
end

// continue outside any loop is a grammar error.
function continueOutside(): void
>continueOutside : Symbol(continueOutside, Decl(tluaBreakContinueErrors.tlua, 3, 3))

  continue;
end

// break nested in a Lua if inside a Lua while is fine.
function breakNested(flag: boolean): number
>breakNested : Symbol(breakNested, Decl(tluaBreakContinueErrors.tlua, 8, 3))
>flag : Symbol(flag, Decl(tluaBreakContinueErrors.tlua, 11, 21))

  while true do
    if flag then
>flag : Symbol(flag, Decl(tluaBreakContinueErrors.tlua, 11, 21))

      break;
    end
    flag = true;
>flag : Symbol(flag, Decl(tluaBreakContinueErrors.tlua, 11, 21))

  end
  return 1;
end

// continue keeps working inside Lua loops (TS keyword, no rejection guard).
function continueInLua(n: number): number
>continueInLua : Symbol(continueInLua, Decl(tluaBreakContinueErrors.tlua, 19, 3))
>n : Symbol(n, Decl(tluaBreakContinueErrors.tlua, 22, 23))

  local i = 0;
>i : Symbol(i, Decl(tluaBreakContinueErrors.tlua, 23, 7))

  local total = 0;
>total : Symbol(total, Decl(tluaBreakContinueErrors.tlua, 24, 7))

  while i < n do
>i : Symbol(i, Decl(tluaBreakContinueErrors.tlua, 23, 7))
>n : Symbol(n, Decl(tluaBreakContinueErrors.tlua, 22, 23))

    i = i + 1;
>i : Symbol(i, Decl(tluaBreakContinueErrors.tlua, 23, 7))
>i : Symbol(i, Decl(tluaBreakContinueErrors.tlua, 23, 7))

    if i == 2 then
>i : Symbol(i, Decl(tluaBreakContinueErrors.tlua, 23, 7))

      continue;
    end
    total = total + i;
>total : Symbol(total, Decl(tluaBreakContinueErrors.tlua, 24, 7))
>total : Symbol(total, Decl(tluaBreakContinueErrors.tlua, 24, 7))
>i : Symbol(i, Decl(tluaBreakContinueErrors.tlua, 23, 7))

  end
  return total;
>total : Symbol(total, Decl(tluaBreakContinueErrors.tlua, 24, 7))

end

