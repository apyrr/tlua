  protected c: number,
>c : Symbol(c, Decl(tluaNoParameterProperties.tlua, 4, 20))

  readonly d: number,
>d : Symbol(d, Decl(tluaNoParameterProperties.tlua, 5, 22))

  override e: number,
>e : Symbol(e, Decl(tluaNoParameterProperties.tlua, 6, 21))

): number
  return a + b + c + d + e;
>a : Symbol(a, Decl(tluaNoParameterProperties.tlua, 2, 18))
>b : Symbol(b, Decl(tluaNoParameterProperties.tlua, 3, 19))
>c : Symbol(c, Decl(tluaNoParameterProperties.tlua, 4, 20))
>d : Symbol(d, Decl(tluaNoParameterProperties.tlua, 5, 22))
>e : Symbol(e, Decl(tluaNoParameterProperties.tlua, 6, 21))

