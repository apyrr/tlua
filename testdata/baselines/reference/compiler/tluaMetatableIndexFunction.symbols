//// [tests/cases/compiler/tluaMetatableIndexFunction.tlua] ////

=== tluaMetatableIndexFunction.tlua ===
// A function __index answers a read of every key its parameter admits, which is an index
// signature rather than a property: nothing names the keys it will be asked for.

// An `any` key could be a key of any domain, so it feeds string and number alike -- the
// rule a computed table key already follows.
local anyMt = { __index = function(t: object, k: any): string return "x"; end };
>anyMt : Symbol(anyMt, Decl(tluaMetatableIndexFunction.tlua, 5, 5))
>__index : Symbol(__index, Decl(tluaMetatableIndexFunction.tlua, 5, 15))
>t : Symbol(t, Decl(tluaMetatableIndexFunction.tlua, 5, 35))
>k : Symbol(k, Decl(tluaMetatableIndexFunction.tlua, 5, 45))

local a = setmetatable({ n = 1 }, anyMt);
>a : Symbol(a, Decl(tluaMetatableIndexFunction.tlua, 6, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 6, 24))
>anyMt : Symbol(anyMt, Decl(tluaMetatableIndexFunction.tlua, 5, 5))

local s1: string = a.whatever;
>s1 : Symbol(s1, Decl(tluaMetatableIndexFunction.tlua, 7, 5))
>a : Symbol(a, Decl(tluaMetatableIndexFunction.tlua, 6, 5))

local s2: string = a[1];
>s2 : Symbol(s2, Decl(tluaMetatableIndexFunction.tlua, 8, 5))
>a : Symbol(a, Decl(tluaMetatableIndexFunction.tlua, 6, 5))

local n1: number = a.n;
>n1 : Symbol(n1, Decl(tluaMetatableIndexFunction.tlua, 9, 5))
>a.n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 6, 24))
>a : Symbol(a, Decl(tluaMetatableIndexFunction.tlua, 6, 5))
>n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 6, 24))

// A concrete key domain keeps to itself: this table answers number keys only.
local numMt = { __index = function(t: object, k: number): boolean return true; end };
>numMt : Symbol(numMt, Decl(tluaMetatableIndexFunction.tlua, 12, 5))
>__index : Symbol(__index, Decl(tluaMetatableIndexFunction.tlua, 12, 15))
>t : Symbol(t, Decl(tluaMetatableIndexFunction.tlua, 12, 35))
>k : Symbol(k, Decl(tluaMetatableIndexFunction.tlua, 12, 45))

local num = setmetatable({ n = 1 }, numMt);
>num : Symbol(num, Decl(tluaMetatableIndexFunction.tlua, 13, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 13, 26))
>numMt : Symbol(numMt, Decl(tluaMetatableIndexFunction.tlua, 12, 5))

local b1: boolean = num[3];
>b1 : Symbol(b1, Decl(tluaMetatableIndexFunction.tlua, 14, 5))
>num : Symbol(num, Decl(tluaMetatableIndexFunction.tlua, 13, 5))

local absent = num.missing;
>absent : Symbol(absent, Decl(tluaMetatableIndexFunction.tlua, 15, 5))
>num : Symbol(num, Decl(tluaMetatableIndexFunction.tlua, 13, 5))

// A literal key widens to its domain, because an index signature may not be keyed by a
// literal -- the same widening a computed key gets.
local litMt = { __index = function(t: object, k: "a"): number return 1; end };
>litMt : Symbol(litMt, Decl(tluaMetatableIndexFunction.tlua, 19, 5))
>__index : Symbol(__index, Decl(tluaMetatableIndexFunction.tlua, 19, 15))
>t : Symbol(t, Decl(tluaMetatableIndexFunction.tlua, 19, 35))
>k : Symbol(k, Decl(tluaMetatableIndexFunction.tlua, 19, 45))

local lit = setmetatable({ n = 1 }, litMt);
>lit : Symbol(lit, Decl(tluaMetatableIndexFunction.tlua, 20, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 20, 26))
>litMt : Symbol(litMt, Decl(tluaMetatableIndexFunction.tlua, 19, 5))

local l1: number = lit["zzz"];
>l1 : Symbol(l1, Decl(tluaMetatableIndexFunction.tlua, 21, 5))
>lit : Symbol(lit, Decl(tluaMetatableIndexFunction.tlua, 20, 5))

// A multi-return __index truncates to its first value at the call boundary, as every other
// call does.
local packMt = { __index = function(t: object, k: any): (string, number) return "x", 1; end };
>packMt : Symbol(packMt, Decl(tluaMetatableIndexFunction.tlua, 25, 5))
>__index : Symbol(__index, Decl(tluaMetatableIndexFunction.tlua, 25, 16))
>t : Symbol(t, Decl(tluaMetatableIndexFunction.tlua, 25, 36))
>k : Symbol(k, Decl(tluaMetatableIndexFunction.tlua, 25, 46))

local pack = setmetatable({ n = 1 }, packMt);
>pack : Symbol(pack, Decl(tluaMetatableIndexFunction.tlua, 26, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 26, 27))
>packMt : Symbol(packMt, Decl(tluaMetatableIndexFunction.tlua, 25, 5))

local p1: string = pack.anything;
>p1 : Symbol(p1, Decl(tluaMetatableIndexFunction.tlua, 27, 5))
>pack : Symbol(pack, Decl(tluaMetatableIndexFunction.tlua, 26, 5))

// Overloads that answer the same key domain both apply: a read of such a key gets whichever
// one Lua dispatches to.
declare overloaded: { __index: { (t: object, k: "a"): number; (t: object, k: "b"): string } };
>overloaded : Symbol(overloaded, Decl(tluaMetatableIndexFunction.tlua, 31, 7))
>__index : Symbol(__index, Decl(tluaMetatableIndexFunction.tlua, 31, 21))
>t : Symbol(t, Decl(tluaMetatableIndexFunction.tlua, 31, 34))
>k : Symbol(k, Decl(tluaMetatableIndexFunction.tlua, 31, 44))
>t : Symbol(t, Decl(tluaMetatableIndexFunction.tlua, 31, 63))
>k : Symbol(k, Decl(tluaMetatableIndexFunction.tlua, 31, 73))

local ov = setmetatable({ n = 1 }, overloaded);
>ov : Symbol(ov, Decl(tluaMetatableIndexFunction.tlua, 32, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 32, 25))
>overloaded : Symbol(overloaded, Decl(tluaMetatableIndexFunction.tlua, 31, 7))

local either: number | string = ov.b;
>either : Symbol(either, Decl(tluaMetatableIndexFunction.tlua, 33, 5))
>ov : Symbol(ov, Decl(tluaMetatableIndexFunction.tlua, 32, 5))

local notJustNumber: number = ov.b;
>notJustNumber : Symbol(notJustNumber, Decl(tluaMetatableIndexFunction.tlua, 34, 5))
>ov : Symbol(ov, Decl(tluaMetatableIndexFunction.tlua, 32, 5))

// The table's own members still win: a function __index only runs on a miss.
local own = setmetatable({ n = 1 }, anyMt);
>own : Symbol(own, Decl(tluaMetatableIndexFunction.tlua, 37, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 37, 26))
>anyMt : Symbol(anyMt, Decl(tluaMetatableIndexFunction.tlua, 5, 5))

local o1: number = own.n;
>o1 : Symbol(o1, Decl(tluaMetatableIndexFunction.tlua, 38, 5))
>own.n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 37, 26))
>own : Symbol(own, Decl(tluaMetatableIndexFunction.tlua, 37, 5))
>n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 37, 26))

local o2: string = own.n;
>o2 : Symbol(o2, Decl(tluaMetatableIndexFunction.tlua, 39, 5))
>own.n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 37, 26))
>own : Symbol(own, Decl(tluaMetatableIndexFunction.tlua, 37, 5))
>n : Symbol(n, Decl(tluaMetatableIndexFunction.tlua, 37, 26))

// ...unless the member can be nil, which is the miss.
declare partial: { v?: number };
>partial : Symbol(partial, Decl(tluaMetatableIndexFunction.tlua, 42, 7))
>v : Symbol(v, Decl(tluaMetatableIndexFunction.tlua, 42, 18))

local fallsThrough = setmetatable(partial, anyMt);
>fallsThrough : Symbol(fallsThrough, Decl(tluaMetatableIndexFunction.tlua, 43, 5))
>setmetatable : Symbol(setmetatable, Decl(lib.luajit.d.tlua, --, --))
>partial : Symbol(partial, Decl(tluaMetatableIndexFunction.tlua, 42, 7))
