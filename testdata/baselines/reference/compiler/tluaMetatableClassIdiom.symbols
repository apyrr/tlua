>amount : Symbol(amount, Decl(tluaMetatableClassIdiom.tlua, 12, 36))

    if self.balance < amount then
>self.balance : Symbol(Account.balance, Decl(tluaMetatableClassIdiom.tlua, 4, 19))
>self : Symbol(self, Decl(tluaMetatableClassIdiom.tlua, 12, 22))
>balance : Symbol(Account.balance, Decl(tluaMetatableClassIdiom.tlua, 4, 19))
>amount : Symbol(amount, Decl(tluaMetatableClassIdiom.tlua, 12, 36))

      return false;
    end
    self.balance = self.balance - amount;
>self.balance : Symbol(Account.balance, Decl(tluaMetatableClassIdiom.tlua, 4, 19))
>self : Symbol(self, Decl(tluaMetatableClassIdiom.tlua, 12, 22))
>balance : Symbol(Account.balance, Decl(tluaMetatableClassIdiom.tlua, 4, 19))
