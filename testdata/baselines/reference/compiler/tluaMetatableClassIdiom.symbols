>self.balance : Symbol(Account.balance, Decl(tluaMetatableClassIdiom.tlua, 4, 19))
>self : Symbol(self, Decl(tluaMetatableClassIdiom.tlua, 11, 21))
>balance : Symbol(Account.balance, Decl(tluaMetatableClassIdiom.tlua, 4, 19))
>amount : Symbol(amount, Decl(tluaMetatableClassIdiom.tlua, 11, 35))

  withdraw = function(self: Account, amount: number): boolean
>withdraw : Symbol(withdraw, Decl(tluaMetatableClassIdiom.tlua, 11, 94))
