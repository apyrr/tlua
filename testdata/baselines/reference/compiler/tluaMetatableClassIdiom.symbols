    return true;
  end,
};

local AccountMeta = { __index = AccountClass };
>AccountMeta : Symbol(AccountMeta, Decl(tluaMetatableClassIdiom.tlua, 21, 5))
>__index : Symbol(__index, Decl(tluaMetatableClassIdiom.tlua, 21, 21))
>AccountClass : Symbol(AccountClass, Decl(tluaMetatableClassIdiom.tlua, 10, 5))

function newAccount(balance: number): Account
