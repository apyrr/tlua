=== tluaMetatableClassIdiom.tlua ===
// The Lua class idiom: a method table behind __index, and a constructor that pairs a fresh
// table with it. The constructor's result satisfies the interface only because of the
// fallback -- the table it builds has a balance and nothing else.

interface Account {
>Account : Symbol(Account, Decl(tluaMetatableClassIdiom.tlua, 0, 0))

  balance: number;
>balance : Symbol(Account.balance, Decl(tluaMetatableClassIdiom.tlua, 4, 19))

  deposit: (self: Account, amount: number) => void;
>deposit : Symbol(Account.deposit, Decl(tluaMetatableClassIdiom.tlua, 5, 18))
>self : Symbol(self, Decl(tluaMetatableClassIdiom.tlua, 6, 12))
>Account : Symbol(Account, Decl(tluaMetatableClassIdiom.tlua, 0, 0))
>amount : Symbol(amount, Decl(tluaMetatableClassIdiom.tlua, 6, 26))

  withdraw: (self: Account, amount: number) => boolean;
>withdraw : Symbol(Account.withdraw, Decl(tluaMetatableClassIdiom.tlua, 6, 51))
>self : Symbol(self, Decl(tluaMetatableClassIdiom.tlua, 7, 13))
>Account : Symbol(Account, Decl(tluaMetatableClassIdiom.tlua, 0, 0))
>amount : Symbol(amount, Decl(tluaMetatableClassIdiom.tlua, 7, 27))
}

local AccountClass = {
>AccountClass : Symbol(AccountClass, Decl(tluaMetatableClassIdiom.tlua, 10, 5))

  deposit = function(self: Account, amount: number) self.balance = self.balance + amount; end,
