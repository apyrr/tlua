// argument is not part of tlua syntax.
type Module = import("./module", { with: { type: "json" } })
>Module : Symbol(Module, Decl(main.tlua, 0, 0))
>type : Symbol(type, Decl(lib.luajit.d.tlua, --, --))

function usesAssert(): number
>usesAssert : Symbol(usesAssert, Decl(main.tlua, 2, 60))

  local assert = 4
>assert : Symbol(assert, Decl(main.tlua, 5, 7))

  return assert
>assert : Symbol(assert, Decl(main.tlua, 5, 7))

end

