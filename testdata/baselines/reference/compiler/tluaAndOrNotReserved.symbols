//// [tests/cases/compiler/tluaAndOrNotReserved.tlua] ////

=== tluaAndOrNotReserved.tlua ===
// `and`, `or` and `not` are keywords, so they are reserved. Every use as a name
// falls into stock recovery, as with the class, decorator, array and this
// removals. Lua reserves them too, so `t.and` is invalid there as well.

local obj = { x = 1 };
>obj : Symbol(obj, Decl(tluaAndOrNotReserved.tlua, 4, 5))
>x : Symbol(x, Decl(tluaAndOrNotReserved.tlua, 4, 13))

// Member names.
local a1 = obj.and;
>a1 : Symbol(a1, Decl(tluaAndOrNotReserved.tlua, 7, 5))
>obj : Symbol(obj, Decl(tluaAndOrNotReserved.tlua, 4, 5))

local a2 = obj.or;
>a2 : Symbol(a2, Decl(tluaAndOrNotReserved.tlua, 8, 5))
>obj : Symbol(obj, Decl(tluaAndOrNotReserved.tlua, 4, 5))

local a3 = obj.not;
>a3 : Symbol(a3, Decl(tluaAndOrNotReserved.tlua, 9, 5))
>obj : Symbol(obj, Decl(tluaAndOrNotReserved.tlua, 4, 5))

// Property names in an object literal.
local o1 = { and = 1 };
>o1 : Symbol(o1, Decl(tluaAndOrNotReserved.tlua, 12, 5))

local o2 = { or = 1 };
>o2 : Symbol(o2, Decl(tluaAndOrNotReserved.tlua, 13, 5))

local o3 = { not = 1 };
>o3 : Symbol(o3, Decl(tluaAndOrNotReserved.tlua, 14, 5))

// Binding names.
local and = 1;
> : Symbol((Missing), Decl(tluaAndOrNotReserved.tlua, 17, 5))

local or = 2;
> : Symbol((Missing), Decl(tluaAndOrNotReserved.tlua, 18, 5))

local not = 3;
> : Symbol((Missing), Decl(tluaAndOrNotReserved.tlua, 19, 5))

// Declaration names.
function or() {}
> : Symbol((Missing), Decl(tluaAndOrNotReserved.tlua, 19, 14))

// `not` shares KindExclamationToken with `!`, but only the punctuation spelling
// is the non-null and definite-assignment operator. Accepting the word in those
// roles would silently suppress a nil check.
declare maybe: number | nil;
>maybe : Symbol(maybe, Decl(tluaAndOrNotReserved.tlua, 27, 7))

local n1 = maybe not;
>n1 : Symbol(n1, Decl(tluaAndOrNotReserved.tlua, 28, 5))
>maybe : Symbol(maybe, Decl(tluaAndOrNotReserved.tlua, 27, 7))

local n2 not: number;
>n2 : Symbol(n2, Decl(tluaAndOrNotReserved.tlua, 29, 5))

// The punctuation spelling keeps both roles.
local n3 = maybe!;
>n3 : Symbol(n3, Decl(tluaAndOrNotReserved.tlua, 31, 5))
>maybe : Symbol(maybe, Decl(tluaAndOrNotReserved.tlua, 27, 7))

local n4!: number;
>n4 : Symbol(n4, Decl(tluaAndOrNotReserved.tlua, 32, 5))

// And the word keeps its own: prefix negation.
local n5 = not maybe;
>n5 : Symbol(n5, Decl(tluaAndOrNotReserved.tlua, 34, 5))
>maybe : Symbol(maybe, Decl(tluaAndOrNotReserved.tlua, 27, 7))

// The type-position `!` (the JSDoc non-nullable operator) is punctuation-only
// as well: the word `not` never silently becomes a type operator.
local n6: number not;
>n6 : Symbol(n6, Decl(tluaAndOrNotReserved.tlua, 38, 5))

type N7 = not number;
>N7 : Symbol(N7, Decl(tluaAndOrNotReserved.tlua, 38, 21))
> : Symbol(unknown)

