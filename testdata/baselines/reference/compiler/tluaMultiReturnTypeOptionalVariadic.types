//// [tests/cases/compiler/tluaMultiReturnTypeOptionalVariadic.tlua] ////

=== tluaMultiReturnTypeOptionalVariadic.tlua ===
// Optional elements: an absent value reads as nil.
function opt(): (number, string?)
>opt : () => (number, string?)

  return 1;
>1 : 1

end

function optBoth(): (number, string?)
>optBoth : () => (number, string?)

  return 1, "a";
>1, "a" : number, string
>1 : 1
>"a" : "a"

end

// The trailing `?` must parse before a brace body (eager `?` consumption).
function optBrace(): (number, string?)
>optBrace : () => (number, string?)

  return 2;
>2 : 2

end

// ... and before a same-line Lua statement.
function optSameLine(cond: boolean): (number, boolean?) local x = cond;
>optSameLine : (cond: boolean) => (number, boolean?)
>cond : boolean
>x : boolean
>cond : boolean

  return 3, x;
>3, x : number, boolean
>3 : 3
>x : boolean

end

// Variadic tail: any number of trailing values.
function variadic(): (number, ...string)
>variadic : () => (number, ...string)

  return 1, "a", "b", "c";
>1, "a", "b", "c" : number, string, string, string
>1 : 1
>"a" : "a"
>"b" : "b"
>"c" : "c"

end

function variadicEmptyTail(): (number, ...string)
>variadicEmptyTail : () => (number, ...string)

  return 1;
>1 : 1

end

// Optional element in the middle position, before a required-of-rest layout.
function optFirstOfTail(): (boolean, number?, ...string)
>optFirstOfTail : () => (boolean, number?, ...string)

  return true, 1, "x";
>true, 1, "x" : true, number, string
>true : true
>1 : 1
>"x" : "x"

end

local a = opt();
>a : number
>opt() : number
>opt : () => (number, string?)

local b = optBoth();
>b : number
>optBoth() : number
>optBoth : () => (number, string?)

local c = optBrace();
>c : number
>optBrace() : number
>optBrace : () => (number, string?)

local d = optSameLine(true);
>d : number
>optSameLine(true) : number
>optSameLine : (cond: boolean) => (number, boolean?)
>true : true

local e = variadic();
>e : number
>variadic() : number
>variadic : () => (number, ...string)

