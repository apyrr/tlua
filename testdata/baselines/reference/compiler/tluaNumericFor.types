function sumTo(n: number): number
>sumTo : (n: number) => number
>n : number

  local total = 0;
>total : number
>0 : 0

  for i = 1, n do
>i : number
>1 : 1
>n : number

    total = total + i;
>total = total + i : number
>total : number
>total + i : number
>total : number
>i : number

  end
  return total;
>total : number

end

// Optional step; the control variable may be assigned.
function countDown(n: number): number
>countDown : (n: number) => number
>n : number

  local last = 0;
>last : number
>0 : 0

  for i = n, 1, -1 do
>i : number
>n : number
>1 : 1
>-1 : -1
>1 : 1

    last = i;
>last = i : number
>last : number
>i : number

    i = i - 1;
>i = i - 1 : number
>i : number
>i - 1 : number
>i : number
>1 : 1

  end
  return last;
>last : number

end

// An annotation is allowed when it accepts a number.
function annotated(n: number): number
>annotated : (n: number) => number
>n : number

  local total = 0;
>total : number
>0 : 0

  for i: number = 1, n do
>i : number
>1 : 1
>n : number

    total = total + i;
>total = total + i : number
>total : number
>total + i : number
>total : number
>i : number

  end
  return total;
>total : number

end

// break works; nesting works; TS body statements work.
function nested(w: number, h: number): number
>nested : (w: number, h: number) => number
>w : number
>h : number

  local count = 0;
>count : number
>0 : 0

  for x = 1, w do
>x : number
>1 : 1
>w : number

    for y = 1, h do
>y : number
>1 : 1
>h : number

      if (count > 100) {
>count > 100 : boolean
>count : number
>100 : 100

        break;
      }
      count = count + 1;
>count = count + 1 : number
>count : number
>count + 1 : number
>count : number
>1 : 1

    end
  end
  return count;
>count : number

end

// The control variable is scoped to the loop.
function scoped(n: number): number
>scoped : (n: number) => number
>n : number

  for i = 1, n do
>i : number
>1 : 1
>n : number

  end
  return i;
>i : any

end

