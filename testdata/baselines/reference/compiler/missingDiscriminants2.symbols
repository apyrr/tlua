//// [tests/cases/compiler/missingDiscriminants2.tlua] ////

=== missingDiscriminants2.tlua ===
// https://github.com/microsoft/typescript-go/issues/1020

// This tests ensures the change also works for discriminated unions with more than 10 cases

type Thing =
>Thing : Symbol(Thing, Decl(missingDiscriminants2.tlua, 0, 0))

  | { str: "a", num: 0 }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 5, 5))
>num : Symbol(num, Decl(missingDiscriminants2.tlua, 5, 15))

  | { str: "b" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 6, 5))

  | { str: "c" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 7, 5))

  | { str: "d" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 8, 5))

  | { str: "e" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 9, 5))

  | { str: "f" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 10, 5))

  | { str: "g" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 11, 5))

  | { str: "h" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 12, 5))

  | { str: "i" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 13, 5))

  | { str: "j" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 14, 5))

  | { str: "k" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 15, 5))

  | { str: "l" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 16, 5))

  | { str: "m" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 17, 5))

  | { str: "n" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 18, 5))

  | { str: "o" }
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 19, 5))

  | { num: 1 }
>num : Symbol(num, Decl(missingDiscriminants2.tlua, 20, 5))

local thing1: Thing = { str = "a", num = 0 }
>thing1 : Symbol(thing1, Decl(missingDiscriminants2.tlua, 22, 5))
>Thing : Symbol(Thing, Decl(missingDiscriminants2.tlua, 0, 0))
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 22, 23))
>num : Symbol(num, Decl(missingDiscriminants2.tlua, 22, 34))

local thing2: Thing = { str = "b", num = 1 } // Shouldn't be error
>thing2 : Symbol(thing2, Decl(missingDiscriminants2.tlua, 23, 5))
>Thing : Symbol(Thing, Decl(missingDiscriminants2.tlua, 0, 0))
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 23, 23))
>num : Symbol(num, Decl(missingDiscriminants2.tlua, 23, 34))

local thing3: Thing = { num = 1, str = "b" } // Shouldn't be error
>thing3 : Symbol(thing3, Decl(missingDiscriminants2.tlua, 24, 5))
>Thing : Symbol(Thing, Decl(missingDiscriminants2.tlua, 0, 0))
>num : Symbol(num, Decl(missingDiscriminants2.tlua, 24, 23))
>str : Symbol(str, Decl(missingDiscriminants2.tlua, 24, 32))

type Item =
>Item : Symbol(Item, Decl(missingDiscriminants2.tlua, 24, 44))

  | { kind: "a", subkind: 0, value: string }
>kind : Symbol(kind, Decl(missingDiscriminants2.tlua, 27, 5))
>subkind : Symbol(subkind, Decl(missingDiscriminants2.tlua, 27, 16))
>value : Symbol(value, Decl(missingDiscriminants2.tlua, 27, 28))

  | { kind: "a", subkind: 1, value: number }
>kind : Symbol(kind, Decl(missingDiscriminants2.tlua, 28, 5))
>subkind : Symbol(subkind, Decl(missingDiscriminants2.tlua, 28, 16))
>value : Symbol(value, Decl(missingDiscriminants2.tlua, 28, 28))

  | { kind: "b" }
>kind : Symbol(kind, Decl(missingDiscriminants2.tlua, 29, 5))

local item1: Item = { subkind = 1, kind = "b" } // Error, type "b" not assignable to type "a"
>item1 : Symbol(item1, Decl(missingDiscriminants2.tlua, 31, 5))
>Item : Symbol(Item, Decl(missingDiscriminants2.tlua, 24, 44))
>subkind : Symbol(subkind, Decl(missingDiscriminants2.tlua, 31, 21))
>kind : Symbol(kind, Decl(missingDiscriminants2.tlua, 31, 34))

local item2: Item = { kind = "b", subkind = 1 } // Error, 'subkind' isn't a known property
>item2 : Symbol(item2, Decl(missingDiscriminants2.tlua, 32, 5))
>Item : Symbol(Item, Decl(missingDiscriminants2.tlua, 24, 44))
>kind : Symbol(kind, Decl(missingDiscriminants2.tlua, 32, 21))
>subkind : Symbol(subkind, Decl(missingDiscriminants2.tlua, 32, 33))

