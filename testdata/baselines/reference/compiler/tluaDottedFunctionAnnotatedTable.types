>a : number
>a : number
>wrong : (a: number) => number
>function(a: number) return a; end : (a: number) => number
>a : number
>a : number

function ops.good(a: number): number
>ops : Ops
>good : (a: number) => number
>a : number

  return a;
>a : number

end

function ops.wrong(a: string): string
>ops : Ops
>wrong : (a: string) => string
