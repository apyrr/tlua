>a : number
}

local ops: Ops = { good = function(a: number) return a; end, wrong = function(a: number) return a; end };
>ops : Ops
>{ good = function(a: number) return a; end, wrong = function(a: number) return a; end } : { good: (a: number) => number; wrong: (a: number) => number; }
>good : (a: number) => number
