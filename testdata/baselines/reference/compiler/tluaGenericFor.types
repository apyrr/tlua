// The first name drops nil (a nil first value ends the loop); the second
// keeps the iterator's declared nil-ability and narrows normally.
function walk(t: string[]): number
>walk : (t: string[]) => number
>t : string[]

  local count = 0;
>count : number
>0 : 0

  for i, s in ipairsLike(t) do
>i : number
>s : string | nil
>ipairsLike(t) : (t: string[], i: number) => (number, string?)
>ipairsLike : (t: string[]) => typeof iterStep
>t : string[]

    count = count + i;
>count = count + i : number
>count : number
>count + i : number
>count : number
>i : number

    if s ~= nil then
>s ~= nil : boolean
>s : string | nil

      count = count + s.length;
>count = count + s.length : number
>count : number
>count + s.length : number
>count : number
>s.length : number
>s : string
>length : number

    end
  end
  return count;
>count : number

end

