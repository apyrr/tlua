//// [tests/cases/compiler/tluaLambdaEmit.tlua] ////

=== tluaLambdaEmit.tlua ===
// A lambda compiles to the Lua function constructor. An expression body
// becomes a single-line `function(x) return x + 1 end`; a braced body inlines
// its statements before `end`.
local function two(): (number, string)
>two : () => (number, string)

  return 1, "s"
>1, "s" : number, string
>1 : 1
>"s" : "s"

end
local add = function(x: number, y: number) return x + y end
>add : (x: number, y: number) => number
>function(x: number, y: number) return x + y end : (x: number, y: number) => number
>x : number
>y : number
>x + y : number
>x : number
>y : number

local block = function(x: number) return x * 2; end
>block : (x: number) => number
>function(x: number) return x * 2; end : (x: number) => number
>x : number
>x * 2 : number
>x : number
>2 : 2

local nested = function(x: number) return function(y: number) return x + y end end
>nested : (x: number) => (y: number) => number
>function(x: number) return function(y: number) return x + y end end : (x: number) => (y: number) => number
>x : number
>function(y: number) return x + y end : (y: number) => number
>y : number
>x + y : number
>x : number
>y : number

local noParams = function() return 42 end
>noParams : () => number
>function() return 42 end : () => number
>42 : 42

// A concise body is typed as one value, but a direct call in Lua tail
// position would propagate its whole pack -- the emit parenthesizes it so the
// runtime truncates to the value the type names.
local truncated = function() return two() end
>truncated : () => (number, string)
>function() return two() end : () => (number, string)
>two() : number
>two : () => (number, string)

local one: number = truncated()
>one : number
>truncated() : number
>truncated : () => (number, string)

// A parenthesized table-literal body keeps its parens; `return { ... } end`
// would also be valid Lua, but the source spelling round-trips.
local table = function() return ({ k = 1 }) end
>table : () => { k: number; }
>function() return ({ k = 1 }) end : () => { k: number; }
>({ k = 1 }) : { k: number; }
>{ k = 1 } : { k: number; }
>k : number
>1 : 1

print(add(1, 2), block(2), nested(1)(2), noParams(), table().k)
>print(add(1, 2), block(2), nested(1)(2), noParams(), table().k) : void
>print : (...: any) => void
>add(1, 2) : number
>add : (x: number, y: number) => number
>1 : 1
>2 : 2
>block(2) : number
>block : (x: number) => number
>2 : 2
>nested(1)(2) : number
>nested(1) : (y: number) => number
>nested : (x: number) => (y: number) => number
>1 : 1
>2 : 2
>noParams() : number
>noParams : () => number
>table().k : number
>table() : { k: number; }
>table : () => { k: number; }
>k : number

