  return 3, x;
>x : Symbol(x, Decl(tluaMultiReturnTypeOptionalVariadic.tlua, 15, 61))

end

// Variadic tail: any number of trailing values.
function variadic(): (number, ...string)
>variadic : Symbol(variadic, Decl(tluaMultiReturnTypeOptionalVariadic.tlua, 17, 3))

  return 1, "a", "b", "c";
end

function variadicEmptyTail(): (number, ...string)
>variadicEmptyTail : Symbol(variadicEmptyTail, Decl(tluaMultiReturnTypeOptionalVariadic.tlua, 22, 3))

  return 1;
end

// Optional element in the middle position, before a required-of-rest layout.
function optFirstOfTail(): (boolean, number?, ...string)
>optFirstOfTail : Symbol(optFirstOfTail, Decl(tluaMultiReturnTypeOptionalVariadic.tlua, 26, 3))

  return true, 1, "x";
end

