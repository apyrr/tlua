>R : Symbol(R, Decl(tluaGenericPackErrors.tlua, 35, 27))
> : Symbol((Missing), Decl(tluaGenericPackErrors.tlua, 35, 56))
>A : Symbol(A, Decl(tluaGenericPackErrors.tlua, 35, 22))
>R : Symbol(R, Decl(tluaGenericPackErrors.tlua, 35, 27))

// Explicit scalar arguments are lifted even when a failed call uses its
