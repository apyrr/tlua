=== tluaColonCallBasic.tlua ===
local M = { count = 0 };
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>{ count = 0 } : { count: number; inc(self: { count: number; inc(self: any, by: number): number; read(self: any): number; }, by: number): number; read(self: { count: number; inc(self: any, by: number): number; read(self: any): number; }): number; }
>count : number
>0 : 0

function M:inc(by: number): number
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>inc : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }, by: number) => number
>: : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>by : number

  self.count = self.count + by;
>self.count = self.count + by : number
>self.count : number
>self : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>count : number
>self.count + by : number
>self.count : number
>self : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>count : number
>by : number

  return self.count;
>self.count : number
>self : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>count : number

end

function M:read(): number
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>read : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }) => number
>: : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }

  return self.count;
>self.count : number
>self : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>count : number

end

// The colon call passes the receiver as the implicit first argument.
local a = M:inc(1);
>a : number
>M:inc(1) : number
>M:inc : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }, by: number) => number
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>inc : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }, by: number) => number
>1 : 1

local b = M:read();
>b : number
>M:read() : number
>M:read : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }) => number
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>read : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }) => number

// It is interchangeable with the explicit form.
local c = M.inc(M, 1);
>c : number
>M.inc(M, 1) : number
>M.inc : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }, by: number) => number
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>inc : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }, by: number) => number
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>1 : 1

// A dotted target chains: `a.b:c()` calls through the member table.
local outer = { inner = M };
>outer : { inner: { count: number; inc(self: any, by: number): number; read(self: any): number; }; }
>{ inner = M } : { inner: { count: number; inc(self: any, by: number): number; read(self: any): number; }; }
>inner : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }

local d = outer.inner:inc(2);
>d : number
>outer.inner:inc(2) : number
>outer.inner:inc : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }, by: number) => number
>outer.inner : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>outer : { inner: { count: number; inc(self: any, by: number): number; read(self: any): number; }; }
>inner : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>inc : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }, by: number) => number
>2 : 2

// Chained colon calls: each link is its own receiver.
interface Chain {
  next(self: Chain): Chain;
>next : (self: Chain) => Chain
>self : Chain

  value(self: Chain): number;
>value : (self: Chain) => number
>self : Chain
}
declare chain: Chain;
>chain : Chain

local e = chain:next():next():value();
>e : number
>chain:next():next():value() : number
>chain:next():next():value : (self: Chain) => number
>chain:next():next() : Chain
>chain:next():next : (self: Chain) => Chain
>chain:next() : Chain
>chain:next : (self: Chain) => Chain
>chain : Chain
>next : (self: Chain) => Chain
>next : (self: Chain) => Chain
>value : (self: Chain) => number

// The colon form also fits an explicit self-typed member on a table value.
local t = {
>t : { base: number; plus: (self: { base: number; }, n: number) => number; }
>{  base = 10,  plus = function(self: { base: number }, n: number) return self.base + n; end,} : { base: number; plus: (self: { base: number; }, n: number) => number; }

  base = 10,
>base : number
>10 : 10

  plus = function(self: { base: number }, n: number) return self.base + n; end,
>plus : (self: { base: number; }, n: number) => number
>function(self: { base: number }, n: number) return self.base + n; end : (self: { base: number; }, n: number) => number
>self : { base: number; }
>base : number
>n : number
>self.base + n : number
>self.base : number
>self : { base: number; }
>base : number
>n : number

};
local f = t:plus(5);
>f : number
>t:plus(5) : number
>t:plus : (self: { base: number; }, n: number) => number
>t : { base: number; plus: (self: { base: number; }, n: number) => number; }
>plus : (self: { base: number; }, n: number) => number
>5 : 5

// A receiver that survived its `?.` guards is not nil at call time: the
// implicit first argument carries the narrowed type, so no spurious mismatch.
local maybe: { inner: typeof M } | nil = { inner = M };
>maybe : { inner: { count: number; inc(self: any, by: number): number; read(self: any): number; }; } | nil
>inner : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>{ inner = M } : { inner: { count: number; inc(self: any, by: number): number; read(self: any): number; }; }
>inner : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>M : { count: number; inc(self: any, by: number): number; read(self: any): number; }

local g = maybe?.inner:read();
>g : number
>maybe?.inner:read() : number
>maybe?.inner:read : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }) => number
>maybe?.inner : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>maybe : { inner: { count: number; inc(self: any, by: number): number; read(self: any): number; }; }
>inner : { count: number; inc(self: any, by: number): number; read(self: any): number; }
>read : (self: { count: number; inc(self: any, by: number): number; read(self: any): number; }) => number

