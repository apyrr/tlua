// === Smart Selection ===
local { /**/x, y: a, ...zs = {} } = {};

        x                          
        x, y                       
        x, y: a, ...zs = {}        
local { x, y: a, ...zs = {} } = {};

================================================================================

local { x, y: /**/a, ...zs = {} } = {};

              a                    
              a, ...               
        x, y: a, ...zs = {}        
local { x, y: a, ...zs = {} } = {};

================================================================================

local { x, y: a, .../**/zs = {} } = {};

                    zs             
                    zs = {}        
        x, y: a, ...zs = {}        
local { x, y: a, ...zs = {} } = {};